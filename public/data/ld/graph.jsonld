        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/requirements/black-box"
      ],
      "complexityRating": 3,
      "computationalCostRating": 2,
      "relatedTo": [
        "tea:technique/local-interpretable-model-agnostic-explanations",
        "tea:technique/rulefit",
        "tea:technique/partial-dependence-plots",
        "tea:technique/coefficient-magnitudes-in-linear-models"
      ],
      "citesResource": [
        "tea:resource/scikit-learndevelopersScikitlearnRidgeRegression2007",
        "tea:resource/InterpretableMachineLearning2019",
        "tea:resource/bastaniInterpretingBlackboxModels2017",
        "tea:resource/jiaModelExtractionDefenses2018"
      ],
      "exampleUseCases": [
        {
          "description": "Approximating a complex ensemble model used for credit scoring with a ridge regression surrogate to identify the most influential features (income, credit history, debt-to-income ratio) and their linear relationships for regulatory compliance reporting.",
          "goal": "Explainability"
        },
        {
          "description": "Creating a ridge regression surrogate of a neural network used for medical diagnosis to understand which patient symptoms and biomarkers have the strongest linear predictive relationships with disease outcomes.",
          "goal": "Explainability"
        },
        {
          "description": "Creating an interpretable approximation of a complex insurance pricing model for regulatory compliance, enabling stakeholders to understand and validate the decision-making process through transparent linear relationships.",
          "goal": "Transparency"
        }
      ],
      "limitations": [
        {
          "description": "Linear approximation may miss important non-linear relationships and interactions captured by the original complex model."
        },
        {
          "description": "Requires a representative dataset to train the surrogate model, which may not be available or may be expensive to generate."
        },
        {
          "description": "Ridge regularisation may oversimplify the model by shrinking coefficients, potentially hiding important but less dominant features."
        },
        {
          "description": "Surrogate fidelity depends on how well linear relationships approximate the original model's behaviour across the entire input space."
        }
      ],
      "sampleClaims": [
        {
          "text": "The model's global behavior is approximated by a simpler representation that captures dominant linear relationships across all predictions",
          "domain": "general",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The credit scoring model's decision logic can be explained through consistent linear weights applied uniformly across all applicant evaluations",
          "domain": "finance",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The diagnostic system's predictions are attributable to weighted combinations of patient features that remain stable across the entire population",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The environmental forecasting model's feature influences are represented through simplified linear coefficients that prioritize robust patterns over noise",
          "domain": "environmental",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The complex ensemble model's overall decision-making process is captured by an interpretable linear approximation that reveals primary feature contributions",
          "domain": "general",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/partial-dependence-plots",
      "@type": "Technique",
      "name": "Partial Dependence Plots",
      "slug": "partial-dependence-plots",
      "description": "Partial Dependence Plots show how changing one or two features affects a model's predictions on average. The technique works by varying the selected feature(s) across their full range whilst keeping all other features fixed at their original values, then averaging the predictions. This creates a clear visualisation of whether increasing or decreasing a feature tends to increase or decrease predictions, and reveals patterns like linear trends, plateaus, or threshold effects that help explain model behaviour.",
      "addressesGoal": [
        "tea:goal/explainability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/attribution-methods/perturbation-based",
        "tea:tag/assurance-goal-category/explainability/explains/data-patterns",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/property/comprehensibility",
        "tea:tag/assurance-goal-category/explainability/property/fidelity",
        "tea:tag/assurance-goal-category/explainability/visualization-methods/feature-relationships",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/visualisation",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/explanatory-scope/global",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "acronym": "PDP",
      "complexityRating": 2,
      "computationalCostRating": 2,
      "relatedTo": [
        "tea:technique/individual-conditional-expectation-plots",
        "tea:technique/shapley-additive-explanations",
        "tea:technique/permutation-importance",
        "tea:technique/local-interpretable-model-agnostic-explanations"
      ],
      "citesResource": [
        "tea:resource/danielkerriganPDPilot2022",
        "tea:resource/goldsteinPeekingBlackBox2013",
        "tea:resource/sosunekoPDPbox2017",
        "tea:resource/muschalikIPDPPartialDependence2023",
        "tea:resource/warnesHowInterpretModels2021"
      ],
      "exampleUseCases": [
        {
          "description": "Analysing how house prices change with property size in a real estate prediction model, revealing whether the relationship is linear or if there are diminishing returns for very large properties.",
          "goal": "Explainability"
        },
        {
          "description": "Examining how customer age affects predicted loan default probability in a credit scoring model, showing whether risk increases steadily with age or has specific age ranges with higher risk.",
          "goal": "Explainability"
        },
        {
          "description": "Visualising how temperature affects crop yield predictions in agricultural models, identifying optimal temperature ranges and potential threshold effects.",
          "goal": "Explainability"
        }
      ],
      "limitations": [
        {
          "description": "Assumes features are independent when averaging, which can be misleading when features are highly correlated."
        },
        {
          "description": "Shows only average effects across all instances, potentially hiding important variations in how different subgroups respond to feature changes."
        },
        {
          "description": "Cannot reveal instance-specific effects or interactions between the plotted feature and other features."
        },
        {
          "description": "May be computationally expensive for large datasets since it requires making predictions across the full range of feature values."
        }
      ],
      "sampleClaims": [
        {
          "text": "The model's predicted patient risk follows a quantifiable functional relationship with clinical measurements across the population",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The credit model's average predicted default probability exhibits identifiable threshold effects at specific income levels",
          "domain": "finance",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The system's output response to environmental variables demonstrates interpretable marginal trends independent of individual site characteristics",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The model's sensitivity to feature changes reveals whether prediction adjustments follow linear, plateau, or non-monotonic patterns",
          "domain": "general",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The autonomous navigation system's predicted safe speed varies systematically with visibility conditions in a manner consistent across different vehicle types",
          "domain": "autonomous systems",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/individual-conditional-expectation-plots",
      "@type": "Technique",
      "name": "Individual Conditional Expectation Plots",
      "slug": "individual-conditional-expectation-plots",
      "description": "Individual Conditional Expectation (ICE) plots display the predicted output for individual instances as a function of a feature, with all other features held fixed for each instance. Each line on an ICE plot represents one instance's prediction trajectory as the feature of interest changes, revealing whether different instances are affected differently by that feature. This complements Partial Dependence Plots by showing heterogeneous effects across individual instances rather than just the average trend.",
      "addressesGoal": [
        "tea:goal/explainability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/explains/data-patterns",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/property/fidelity",
        "tea:tag/assurance-goal-category/explainability/visualization-methods/feature-relationships",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/visualisation",
        "tea:tag/expertise-needed/low",
        "tea:tag/explanatory-scope/global",
        "tea:tag/explanatory-scope/local",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/visualization"
      ],
      "acronym": "ICE",
      "complexityRating": 2,
      "computationalCostRating": 2,
      "relatedTo": [
        "tea:technique/partial-dependence-plots",
        "tea:technique/shapley-additive-explanations",
        "tea:technique/permutation-importance",
        "tea:technique/local-interpretable-model-agnostic-explanations"
      ],
      "citesResource": [
        "tea:resource/goldsteinPeekingBlackBox2013",
        "tea:resource/yehBringingRulerBlack2021",
        "tea:resource/bhatnagarExplainableAIXAIGuide2021",
        "tea:resource/mehdiyevCommunicatingUncertaintyMachine2023"
      ],
      "exampleUseCases": [
        {
          "description": "Examining how house price predictions vary with property age for individual properties, revealing that whilst most houses follow a declining price trend with age, historic properties (built before 1900) show different patterns due to heritage value.",
          "goal": "Explainability"
        },
        {
          "description": "Analysing how individual patients' diabetes risk predictions change with BMI, showing that whilst most patients follow the expected increasing risk pattern, some patients with specific genetic markers show different response curves.",
          "goal": "Explainability"
        }
      ],
      "limitations": [
        {
          "description": "Plots can become cluttered and difficult to interpret when displaying many instances simultaneously."
        },
        {
          "description": "Does not provide automatic summarisation of overall effects, requiring manual visual inspection to identify patterns."
        },
        {
          "description": "Still assumes all other features remain fixed at their observed values, which may not reflect realistic scenarios."
        },
        {
          "description": "Cannot reveal interactions between the plotted feature and other features for individual instances."
        }
      ],
      "sampleClaims": [
        {
          "text": "The model's feature-response relationship varies across individual patient subgroups in clinically interpretable ways",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The prediction trajectories for individual samples reveal heterogeneous effects that differ from the population-average trend",
          "domain": "general",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The flood model shows distinct response patterns to rainfall intensity across different watershed characteristics",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The loan pricing model's sensitivity to income varies across applicant profiles without averaging over these differences",
          "domain": "finance",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/saliency-maps",
      "@type": "Technique",
      "name": "Saliency Maps",
      "slug": "saliency-maps",
      "description": "Saliency maps are visual explanations for image classification models that highlight which pixels in an image most strongly influence the model's prediction. Computed by calculating gradients of the model's output with respect to input pixels, saliency maps produce heatmaps where brighter regions indicate pixels that, when changed, would most significantly affect the prediction. This technique helps users understand which parts of an image the model is 'looking at' when making decisions.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/fairness"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/neural-networks",
        "tea:tag/applicable-models/requirements/differentiable",
        "tea:tag/applicable-models/requirements/gradient-access",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/attribution-methods/gradient-based",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/property/comprehensibility",
        "tea:tag/assurance-goal-category/explainability/property/efficiency",
        "tea:tag/assurance-goal-category/explainability/visualization-methods/activation-maps",
        "tea:tag/assurance-goal-category/fairness",
        "tea:tag/data-requirements/access-to-model-internals",
        "tea:tag/data-type/image",
        "tea:tag/evidence-type/visualisation",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/explanatory-scope/local",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "complexityRating": 3,
      "computationalCostRating": 2,
      "relatedTo": [
        "tea:technique/gradient-weighted-class-activation-mapping",
        "tea:technique/integrated-gradients",
        "tea:technique/occlusion-sensitivity",
        "tea:technique/layer-wise-relevance-propagation"
      ],
      "citesResource": [
        "tea:resource/simonyanDeepConvolutionalNetworks2013",
        "tea:resource/utkuozbulakPytorchcnnvisualizations2017",
        "tea:resource/xaitk-saliencydevelopersConceptsSaliencyExplainability",
        "tea:resource/xaitk-saliencydevelopersOcclusionSaliencyExample"
      ],
      "exampleUseCases": [
        {
          "description": "Analysing X-ray images in a pneumonia detection model to verify that the algorithm focuses on lung regions showing inflammatory patterns rather than irrelevant areas like medical equipment or patient positioning markers.",
          "goal": "Explainability"
        },
        {
          "description": "Examining skin lesion classification models to ensure the algorithm identifies diagnostic features (irregular borders, colour variation) rather than artifacts like rulers, hair, or skin markings that shouldn't influence medical decisions.",
          "goal": "Explainability"
        },
        {
          "description": "Auditing a dermatology AI system to verify it focuses on medical symptoms rather than skin colour when diagnosing conditions, ensuring equitable treatment across racial groups by revealing inappropriate attention to demographic features.",
          "goal": "Fairness"
        }
      ],
      "limitations": [
        {
          "description": "Saliency maps are often noisy and can change dramatically with small input perturbations, making them unstable."
        },
        {
          "description": "Highlighted regions may not correspond to semantically meaningful or human-understandable features."
        },
        {
          "description": "Only indicates local gradient information, not causal importance or actual decision-making logic."
        },
        {
          "description": "May highlight irrelevant pixels that happen to have high gradients due to model artifacts rather than meaningful patterns."
        }
      ],
      "sampleClaims": [
        {
          "text": "The medical imaging system's diagnostic predictions are attributable to specific pixel-level regions within the anatomical structures under examination",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The autonomous vehicle's object detection decisions focus on fine-grained visual features rather than irrelevant background elements or environmental artifacts",
          "domain": "autonomous systems",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The facial recognition system's identity predictions do not rely disproportionately on demographic-indicating facial features across different population groups",
          "domain": "general",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The agricultural disease classifier's predictions are traceable to individual pixels showing visible pathological symptoms rather than contextual farm equipment or environmental conditions",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The dermatology screening tool's risk assessments identify fine-scale visual patterns in lesion characteristics independent of skin tone variations",
          "domain": "healthcare",
          "assuranceGoal": "fairness"
        }
      ]
    },
    {
      "@id": "tea:technique/gradient-weighted-class-activation-mapping",
      "@type": "Technique",
      "name": "Gradient-weighted Class Activation Mapping",
      "slug": "gradient-weighted-class-activation-mapping",
      "description": "Grad-CAM creates visual heatmaps showing which regions of an image a convolutional neural network focuses on when making a specific classification. Unlike pixel-level techniques, Grad-CAM produces coarser region-based explanations by using gradients from the predicted class to weight the CNN's final feature maps, then projecting these weighted activations back to create an overlay on the original image. This provides intuitive visual explanations of where the model is 'looking' for evidence of different classes.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/fairness"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/neural-networks/convolutional",
        "tea:tag/applicable-models/requirements/architecture-specific",
        "tea:tag/applicable-models/requirements/gradient-access",
        "tea:tag/applicable-models/requirements/white-box",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/attribution-methods/gradient-based",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/explains/internal-mechanisms",
        "tea:tag/assurance-goal-category/explainability/property/comprehensibility",
        "tea:tag/assurance-goal-category/explainability/property/efficiency",
        "tea:tag/assurance-goal-category/explainability/property/sparsity",
        "tea:tag/assurance-goal-category/explainability/visualization-methods/activation-maps",
        "tea:tag/assurance-goal-category/fairness",
        "tea:tag/data-requirements/access-to-model-internals",
        "tea:tag/data-type/image",
        "tea:tag/evidence-type/visualisation",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/explanatory-scope/local",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "acronym": "Grad-CAM",
      "complexityRating": 3,
      "computationalCostRating": 2,
      "relatedTo": [
        "tea:technique/integrated-gradients",
        "tea:technique/saliency-maps",
        "tea:technique/occlusion-sensitivity",
        "tea:technique/local-interpretable-model-agnostic-explanations"
      ],
      "citesResource": [
        "tea:resource/r.selvarajuGradCAMVisualExplanations2016",
        "tea:resource/jacobgilPytorchgradcam2017",
        "tea:resource/rosebrockGradCAMVisualizeClass2020",
        "tea:resource/kazuto1011Gradcampytorch2017",
        "tea:resource/kamfungyuenTutorialExplainableImage2024",
        "tea:resource/vishwakarmaGuideGradCAMDeep2023"
      ],
      "exampleUseCases": [
        {
          "description": "Validating that a melanoma detection model focuses on the actual skin lesion rather than surrounding healthy skin, medical equipment, or artifacts when making cancer/benign classifications.",
          "goal": "Explainability"
        },
        {
          "description": "Debugging an autonomous vehicle's traffic sign recognition system by visualising whether the model correctly focuses on the sign itself rather than background objects, shadows, or irrelevant visual elements.",
          "goal": "Explainability"
        },
        {
          "description": "Auditing a medical imaging system for racial bias by examining whether diagnostic predictions inappropriately focus on skin tone regions rather than actual pathological features, ensuring equitable healthcare AI deployment.",
          "goal": "Fairness"
        }
      ],
      "limitations": [
        {
          "description": "Requires access to the CNN's internal feature maps and gradients, limiting use to white-box scenarios."
        },
        {
          "description": "Resolution is constrained by the final convolutional layer's feature map size, producing coarser localisation than pixel-level methods."
        },
        {
          "description": "Only applicable to CNN architectures with clearly defined convolutional layers, not suitable for other neural network types."
        },
        {
          "description": "May highlight regions that correlate with the class but aren't causally important for the model's decision-making process."
        }
      ],
      "sampleClaims": [
        {
          "text": "The diagnostic model's predictions are grounded in visually identifiable image regions that align with clinical features",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The perception system's object classifications are traceable to specific spatial regions within the visual field",
          "domain": "autonomous systems",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The medical imaging system's predictions do not disproportionately weight irrelevant visual characteristics across patient groups",
          "domain": "healthcare",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The environmental monitoring system's land cover classifications are anchored to interpretable spatial patterns in satellite imagery",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The vision model's decision-making process reveals which image regions contribute most strongly to each class prediction",
          "domain": "general",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/occlusion-sensitivity",
      "@type": "Technique",
      "name": "Occlusion Sensitivity",
      "slug": "occlusion-sensitivity",
      "description": "Occlusion sensitivity tests which parts of the input are important by occluding (masking or removing) them and seeing how the model's prediction changes. For example, portions of an image can be covered up in a sliding window fashion; if the model's confidence drops significantly when a certain region is occluded, that region was important for the prediction. This technique is model-agnostic and provides highly interpretable results by directly showing which spatial regions drive model decisions.",
      "addressesGoal": [
        "tea:goal/explainability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/attribution-methods/perturbation-based",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/property/sparsity",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/image",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/explanatory-scope/local",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "complexityRating": 2,
      "computationalCostRating": 4,
      "relatedTo": [
        "tea:technique/saliency-maps",
        "tea:technique/gradient-weighted-class-activation-mapping",
        "tea:technique/integrated-gradients",
        "tea:technique/local-interpretable-model-agnostic-explanations"
      ],
      "citesResource": [
        "tea:resource/kazuto1011Gradcampytorch2017",
        "tea:resource/valoisOcclusionSensitivityAnalysis2023",
        "tea:resource/tf-explaindevelopersOcclusionSensitivityTfexplain2020",
        "tea:resource/uchiyamaAdaptiveOcclusionSensitivity2022",
        "tea:resource/sicaraTfexplain2019"
      ],
      "exampleUseCases": [
        {
          "description": "Testing which regions of a chest X-ray are critical for pneumonia detection by systematically covering different areas with grey patches and measuring how much the model's confidence drops for each occluded region.",
          "goal": "Explainability"
        },
        {
          "description": "Evaluating whether a facial recognition system relies on specific facial features by masking eyes, nose, mouth, or other regions to identify which areas cause the biggest drop in recognition accuracy.",
          "goal": "Explainability"
        },
        {
          "description": "Analysing agricultural crop disease classification models to verify that predictions focus on visible disease symptoms (discolouration, lesions, wilting) rather than background elements like soil or irrigation equipment, ensuring reliable deployment across different farm environments.",
          "goal": "Explainability"
        }
      ],
      "limitations": [
        {
          "description": "Computationally expensive as it requires running inference multiple times for each region tested, scaling poorly with input size."
        },
        {
          "description": "Choice of occlusion size and shape can significantly bias results - too small may miss important features, too large may occlude multiple relevant regions simultaneously."
        },
        {
          "description": "Cannot capture interactions between multiple regions that jointly contribute to the prediction but are individually less important."
        },
        {
          "description": "Results may be misleading if the model adapts to occlusion patterns or if occluded regions are filled with unrealistic pixel values."
        }
      ],
      "sampleClaims": [
        {
          "text": "The diagnostic system's classifications remain stable when non-pathological image regions are masked or removed",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The model's predictions depend on spatially localized features that can be identified without requiring access to internal parameters",
          "domain": "general",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The perception system's object detection confidence degrades predictably when visually occluding individual components of recognized entities",
          "domain": "autonomous systems",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The visual classifier's decision-making relies on specific contiguous regions rather than distributed patterns across the entire input",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/classical-attention-analysis-in-neural-networks",
      "@type": "Technique",
      "name": "Classical Attention Analysis in Neural Networks",
      "slug": "classical-attention-analysis-in-neural-networks",
      "description": "Classical attention mechanisms in RNNs and CNNs create alignment matrices and temporal attention patterns that show how models focus on different input elements over time or space. This technique analyses these traditional attention patterns, particularly in encoder-decoder architectures and sequence-to-sequence models, where attention weights reveal which source elements influence each output step. Unlike transformer self-attention analysis, this focuses on understanding alignment patterns, temporal dependencies, and encoder-decoder attention dynamics in classical neural architectures.",
      "addressesGoal": [
        "tea:goal/explainability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/neural-networks/recurrent",
        "tea:tag/applicable-models/requirements/architecture-specific",
        "tea:tag/applicable-models/requirements/model-internals",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/explains/internal-mechanisms",
        "tea:tag/assurance-goal-category/explainability/property/fidelity",
        "tea:tag/assurance-goal-category/explainability/representation-analysis/decomposition",
        "tea:tag/assurance-goal-category/explainability/visualization-methods/attention-patterns",
        "tea:tag/data-requirements/access-to-model-internals",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/visualisation",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/explanatory-scope/local",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "complexityRating": 2,
      "computationalCostRating": 1,
      "relatedTo": [
        "tea:technique/contextual-decomposition",
        "tea:technique/attention-visualisation-in-transformers",
        "tea:technique/layer-wise-relevance-propagation",
        "tea:technique/gradient-weighted-class-activation-mapping"
      ],
      "citesResource": [
        "tea:resource/chaudhariAttentiveSurveyAttention2019",
        "tea:resource/desantanacorreiaAttentionPleaseSurvey2021",
        "tea:resource/jalammarEcco2020",
        "tea:resource/nithyaEnhancingSentimentAnalysis2023",
        "tea:resource/rodriguezCanNeuralNetworks2019"
      ],
      "exampleUseCases": [
        {
          "description": "Analysing encoder-decoder attention in a neural machine translation model to verify the alignment between source and target words, ensuring the model learns proper translation correspondences rather than positional biases.",
          "goal": "Explainability"
        },
        {
          "description": "Examining temporal attention patterns in an RNN-based image captioning model to understand how attention moves across different image regions as it generates each word of the caption description.",
          "goal": "Explainability"
        }
      ],
      "limitations": [
        {
          "description": "Attention weights are not always strongly correlated with feature importance for the final prediction."
        },
        {
          "description": "High attention does not necessarily imply causal influence - models can attend to irrelevant but correlated features."
        },
        {
          "description": "Only applicable to neural network architectures that explicitly use attention mechanisms."
        },
        {
          "description": "Interpretation can be misleading without understanding the specific attention mechanism implementation and training dynamics."
        }
      ],
      "sampleClaims": [
        {
          "text": "The translation model's alignment between source and target sequences reflects semantic correspondence rather than positional artifacts",
          "domain": "general",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The medical image captioning system's attention shifts systematically across anatomical regions as it generates each descriptive phrase",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The document summarization model's encoder-decoder attention weights reveal which source sentences contribute to each summary statement",
          "domain": "public sector",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The financial report generation system focuses on relevant numerical data and contextual information when producing narrative descriptions",
          "domain": "finance",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/factor-analysis",
      "@type": "Technique",
      "name": "Factor Analysis",
      "slug": "factor-analysis",
      "description": "Factor analysis is a statistical technique that identifies latent variables (hidden factors) underlying observed correlations in data. It works by analysing how variables relate to each other, finding a smaller number of unobserved factors that explain patterns among multiple observed variables. Unlike PCA which maximises total variance, factor analysis focuses on shared variance (communalities - the variance variables have in common) whilst separating out unique variance and measurement error. After extracting factors, rotation methods like varimax (which creates uncorrelated factors) or oblimin (allowing correlated factors) help make factors more interpretable by aligning them with distinct groups of variables.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/transparency"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/paradigm/unsupervised",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/explains/data-patterns",
        "tea:tag/assurance-goal-category/explainability/explains/internal-mechanisms",
        "tea:tag/assurance-goal-category/explainability/property/comprehensibility",
        "tea:tag/assurance-goal-category/explainability/representation-analysis/dimensionality-reduction",
        "tea:tag/assurance-goal-category/transparency",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/tabular",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/evidence-type/structured-output",
        "tea:tag/expertise-needed/statistics",
        "tea:tag/explanatory-scope/global",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "complexityRating": 3,
      "computationalCostRating": 3,
      "relatedTo": [
        "tea:technique/principal-component-analysis",
        "tea:technique/t-sne",
        "tea:technique/umap",
        "tea:technique/prototype-and-criticism-models"
      ],
      "citesResource": [
        "tea:resource/ghojoghFactorAnalysisProbabilistic2021",
        "tea:resource/FactorAnalysisCourse2024",
        "tea:resource/educationaltestingserviceFactor_analyzer2017",
        "tea:resource/bastosConfirmatoryFactorAnalysis2021"
      ],
      "exampleUseCases": [
        {
          "description": "Analysing customer satisfaction surveys to identify key drivers (e.g., 'service quality', 'product value', 'convenience') from dozens of individual questions, helping businesses focus improvement efforts.",
          "goal": "Explainability"
        },
        {
          "description": "Reducing dimensionality of financial indicators to identify underlying economic factors (e.g., 'growth', 'inflation', 'credit risk') for more interpretable risk models.",
          "goal": "Explainability"
        },
        {
          "description": "Creating transparent feature groups for regulatory reporting by showing how multiple correlated features can be summarised into interpretable factors with clear business meaning.",
          "goal": "Transparency"
        }
      ],
      "limitations": [
        {
          "description": "Assumes linear relationships between variables and multivariate normality of data."
        },
        {
          "description": "Results can be abstract and require domain expertise to interpret meaningfully."
        },
        {
          "description": "Sensitive to the choice of number of factors and rotation method, which can significantly affect interpretability."
        },
        {
          "description": "Requires sufficiently large sample sizes relative to the number of variables for stable results."
        }
      ],
      "sampleClaims": [
        {
          "text": "The model's high-dimensional input features are reducible to a smaller set of interpretable constructs with clear business meaning",
          "domain": "finance",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The system's documented risk indicators are organized into coherent thematic categories that align with regulatory requirements",
          "domain": "finance",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The survey instrument measures distinct underlying dimensions of patient experience rather than redundant overlapping concepts",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The feature space reveals latent factors that explain correlated environmental measurements without relying on predetermined variable groupings",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The model's feature relationships are explained through identifiable shared sources of variation rather than opaque correlations",
          "domain": "general",
          "assuranceGoal": "transparency"
        }
      ]
    },
    {
      "@id": "tea:technique/principal-component-analysis",
      "@type": "Technique",
      "name": "Principal Component Analysis",
      "slug": "principal-component-analysis",
      "description": "Principal Component Analysis transforms high-dimensional data into a lower-dimensional representation by finding the directions (principal components) that capture the maximum variance in the data. Each component is a linear combination of original features, with the first component explaining the most variance, the second component the most remaining variance orthogonal to the first, and so on. This technique reveals underlying patterns in data structure, enables visualisation of complex datasets, and helps identify which combinations of features drive the most variation in the data.",
      "addressesGoal": [
        "tea:goal/explainability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/paradigm/unsupervised",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/explains/data-patterns",
        "tea:tag/assurance-goal-category/explainability/property/comprehensibility",
        "tea:tag/assurance-goal-category/explainability/representation-analysis/dimensionality-reduction",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/evidence-type/visualisation",
        "tea:tag/expertise-needed/statistics",
        "tea:tag/explanatory-scope/global",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "acronym": "PCA",
      "complexityRating": 2,
      "computationalCostRating": 2,
      "relatedTo": [
        "tea:technique/factor-analysis",
        "tea:technique/t-sne",
        "tea:technique/umap",
        "tea:technique/sobol-indices"
      ],
      "citesResource": [
        "tea:resource/erdogantPca2020",
        "tea:resource/brownleeHowCalculatePrincipal2018",
        "tea:resource/he/himOneStopShopPrincipal2017",
        "tea:resource/priyaPrincipalComponentAnalysis2023",
        "tea:resource/willtownesGlmpcapy2019"
      ],
      "exampleUseCases": [
        {
          "description": "Analysing customer behavior data with dozens of variables (purchase frequency, spending patterns, demographics) to identify the 2-3 main dimensions that explain customer segmentation, revealing whether customers cluster by spending level, product preferences, or shopping frequency.",
          "goal": "Explainability"
        },
        {
          "description": "Reducing dimensionality of image data for facial recognition systems by finding the principal components that capture the most variation in face shapes and expressions, helping understand which facial features contribute most to distinguishing between individuals.",
          "goal": "Explainability"
        }
      ],
      "limitations": [
        {
          "description": "Principal components are abstract linear combinations of original features that often lack clear real-world interpretation or meaning."
        },
        {
          "description": "Only captures linear relationships between features, missing non-linear patterns and complex interactions in the data."
        },
        {
          "description": "Results are highly sensitive to feature scaling - features with larger numerical ranges can dominate the principal components."
        },
        {
          "description": "Information loss is inherent when reducing dimensions, and choosing the optimal number of components requires balancing simplicity with retained variance."
        }
      ],
      "sampleClaims": [
        {
          "text": "The feature space reveals latent factors that explain correlated environmental measurements without relying on predetermined variable groupings",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The model's high-dimensional patient data is reducible to a small number of orthogonal patterns that capture most variation in clinical measurements",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The financial indicators decompose into uncorrelated variance components that reveal which measurement combinations drive portfolio risk",
          "domain": "finance",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The image representation preserves maximal variance through linear transformations that identify which pixel combinations distinguish between object categories",
          "domain": "autonomous systems",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The customer behavior measurements organize into ordered variance patterns showing which feature combinations best separate distinct market segments",
          "domain": "general",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/t-sne",
      "@type": "Technique",
      "name": "t-SNE",
      "slug": "t-sne",
      "description": "t-SNE (t-Distributed Stochastic Neighbour Embedding) is a non-linear dimensionality reduction technique that creates 2D or 3D visualisations of high-dimensional data by preserving local neighbourhood relationships. The algorithm converts similarities between data points into joint probabilities in the high-dimensional space, then tries to minimise the divergence between these probabilities and those in the low-dimensional embedding. This approach excels at revealing cluster structures and local patterns, making it particularly effective for exploratory data analysis and understanding complex data relationships that linear methods like PCA might miss.",
      "addressesGoal": [
        "tea:goal/explainability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/explains/data-patterns",
        "tea:tag/assurance-goal-category/explainability/explains/internal-mechanisms",
        "tea:tag/assurance-goal-category/explainability/property/comprehensibility",
        "tea:tag/assurance-goal-category/explainability/representation-analysis/dimensionality-reduction",
        "tea:tag/assurance-goal-category/explainability/visualization-methods/feature-relationships",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/visualisation",
        "tea:tag/expertise-needed/statistics",
        "tea:tag/explanatory-scope/global",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/visualization"
      ],
      "complexityRating": 3,
      "computationalCostRating": 4,
      "relatedTo": [
        "tea:technique/umap",
        "tea:technique/principal-component-analysis",
        "tea:technique/prototype-and-criticism-models",
        "tea:technique/factor-analysis"
      ],
      "citesResource": [
        "tea:resource/pavlin-policarOpenTSNE2018",
        "tea:resource/opentsnedevelopersOpenTSNEExtensibleParallel",
        "tea:resource/opentsnedevelopersHowTSNEWorks2023",
        "tea:resource/pieniazekTSNEScratchFt2023"
      ],
      "exampleUseCases": [
        {
          "description": "Analyzing genomic data with thousands of gene expression features to visualize how different cancer subtypes cluster together, revealing which tumors have similar molecular signatures and potentially similar treatment responses.",
          "goal": "Explainability"
        },
        {
          "description": "Exploring deep learning model embeddings to understand how a neural network represents different categories of images, showing whether the model groups similar objects (cars, animals, furniture) in meaningful clusters in its internal feature space.",
          "goal": "Explainability"
        }
      ],
      "limitations": [
        {
          "description": "Non-deterministic algorithm produces different results on each run, making it difficult to reproduce exact visualizations or compare results across studies."
        },
        {
          "description": "Prioritizes preserving local neighborhood structure at the expense of global relationships, potentially creating misleading impressions about overall data topology."
        },
        {
          "description": "Computationally expensive with O(n²) complexity, making it impractical for datasets with more than ~10,000 points without approximation methods."
        },
        {
          "description": "Sensitive to hyperparameter choices (perplexity, learning rate, iterations) that can dramatically affect clustering patterns and require domain expertise to tune appropriately."
        }
      ],
      "sampleClaims": [
        {
          "text": "The model's internal representations reveal distinct local neighborhoods corresponding to clinically meaningful disease subtypes",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "Similar customer profiles cluster together in the reduced representation while maintaining separation between behaviorally distinct segments",
          "domain": "finance",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The high-dimensional embedding space exhibits locally coherent structure that corresponds to interpretable data groupings",
          "domain": "general",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The sensor data's local proximity relationships in the reduced visualization reflect genuine environmental similarity patterns",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        },
        {
          "text": "Complex gene expression patterns are rendered into interpretable clusters that preserve biological relationships between nearby cell types",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/umap",
      "@type": "Technique",
      "name": "UMAP",
      "slug": "umap",
      "description": "UMAP (Uniform Manifold Approximation and Projection) is a non-linear dimensionality reduction technique that creates 2D or 3D visualisations of high-dimensional data by constructing a mathematical model of the data's underlying manifold structure. Unlike t-SNE, UMAP preserves both local neighbourhood relationships and global topology more effectively, using techniques from topological data analysis and Riemannian geometry. This approach often produces more interpretable cluster layouts while maintaining meaningful distances between clusters, making it particularly valuable for exploratory data analysis and understanding complex dataset structures.",
      "addressesGoal": [
        "tea:goal/explainability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/explains/data-patterns",
        "tea:tag/assurance-goal-category/explainability/property/fidelity",
        "tea:tag/assurance-goal-category/explainability/representation-analysis/dimensionality-reduction",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/visualisation",
        "tea:tag/expertise-needed/statistics",
        "tea:tag/explanatory-scope/global",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/visualization"
      ],
      "complexityRating": 3,
      "computationalCostRating": 3,
      "relatedTo": [
        "tea:technique/t-sne",
        "tea:technique/principal-component-analysis",
        "tea:technique/factor-analysis",
        "tea:technique/prototype-and-criticism-models"
      ],
      "citesResource": [
        "tea:resource/lmcinnesUmap2017",
        "tea:resource/mcinnesUMAPUniformManifold2018",
        "tea:resource/ghojoghUniformManifoldApproximation2021",
        "tea:resource/umap-learndevelopersHowUMAPWorks2018"
      ],
      "exampleUseCases": [
        {
          "description": "Analysing single-cell RNA sequencing data to visualise how different cell types cluster based on gene expression patterns, revealing developmental trajectories and identifying previously unknown cell subtypes in tissue samples.",
          "goal": "Explainability"
        },
        {
          "description": "Exploring customer segmentation by reducing hundreds of behavioural and demographic features to 2D space, showing how different customer groups relate to each other and identifying transition zones where customers might move between segments.",
          "goal": "Explainability"
        }
      ],
      "limitations": [
        {
          "description": "Hyperparameter choices (n_neighbors, min_dist, metric) significantly influence the embedding structure and can lead to very different interpretations of the same data."
        },
        {
          "description": "While preserving global structure better than t-SNE, distances in the reduced space still don't directly correspond to distances in the original feature space."
        },
        {
          "description": "Performance can be sensitive to the choice of distance metric, which may not be obvious for complex or mixed data types."
        },
        {
          "description": "Like other manifold learning techniques, it assumes the data lies on a lower-dimensional manifold, which may not hold for all datasets."
        }
      ],
      "sampleClaims": [
        {
          "text": "The high-dimensional dataset's underlying cluster relationships are visualized while preserving meaningful distances between distinct groups",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The data visualization reveals both local neighborhood patterns and global topology without sacrificing one for the other",
          "domain": "finance",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The model's learned representations can be explored through low-dimensional projections that preserve the manifold structure of the original feature space",
          "domain": "autonomous systems",
          "assuranceGoal": "explainability"
        },
        {
          "text": "Complex dataset structures with non-linear relationships are comprehensible through two-dimensional visualizations that maintain topological fidelity",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/prototype-and-criticism-models",
      "@type": "Technique",
      "name": "Prototype and Criticism Models",
      "slug": "prototype-and-criticism-models",
      "description": "Prototype and Criticism Models provide data understanding by identifying two complementary sets of examples: prototypes represent the most typical instances that best summarise common patterns in the data, whilst criticisms are outliers or edge cases that are poorly represented by the prototypes. For example, in a dataset of customer transactions, prototypes might be the most representative buying patterns (frequent small purchases, occasional large purchases), whilst criticisms could be unusual behaviours (bulk buyers, one-time high-value customers). This dual approach reveals both what is normal and what is exceptional, helping understand data coverage and model blind spots.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/fairness"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/paradigm/supervised",
        "tea:tag/applicable-models/paradigm/unsupervised",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/applicable-models/requirements/training-data",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/explains/data-patterns",
        "tea:tag/assurance-goal-category/explainability/explains/decision-boundaries",
        "tea:tag/assurance-goal-category/explainability/instance-based/prototypes",
        "tea:tag/assurance-goal-category/explainability/property/comprehensibility",
        "tea:tag/assurance-goal-category/explainability/property/sparsity",
        "tea:tag/assurance-goal-category/fairness",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/structured-output",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/explanatory-scope/global",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "complexityRating": 4,
      "computationalCostRating": 3,
      "relatedTo": [
        "tea:technique/influence-functions",
        "tea:technique/t-sne",
        "tea:technique/umap",
        "tea:technique/contrastive-explanation-method"
      ],
      "citesResource": [
        "tea:resource/kimExamplesAreNot2016",
        "tea:resource/seldonioAlibi2019",
        "tea:resource/bienPrototypeSelectionInterpretable2012",
        "tea:resource/AlibiExplainDocumentation2019"
      ],
      "exampleUseCases": [
        {
          "description": "Analysing medical imaging datasets to identify prototype scans that represent typical healthy tissue patterns and criticism examples showing rare disease presentations, helping radiologists understand what the model considers 'normal' versus cases requiring special attention.",
          "goal": "Explainability"
        },
        {
          "description": "Evaluating credit scoring models by finding prototype borrowers who represent typical low-risk profiles and criticism cases showing unusual but legitimate financial patterns that the model might misclassify, ensuring fair treatment of edge cases.",
          "goal": "Explainability"
        },
        {
          "description": "Evaluating representation bias in hiring datasets by examining whether prototypes systematically exclude certain demographic groups and criticisms disproportionately represent minorities, revealing data collection inequities.",
          "goal": "Fairness"
        }
      ],
      "limitations": [
        {
          "description": "Selection of prototypes and criticisms is highly dependent on the choice of distance metric or similarity measure, which may not capture all meaningful relationships in the data."
        },
        {
          "description": "Computational complexity can become prohibitive for very large datasets, as the method often requires pairwise comparisons or optimisation over the entire dataset."
        },
        {
          "description": "The number of prototypes and criticisms to select is typically a hyperparameter that requires domain expertise to set appropriately."
        },
        {
          "description": "Results may not generalise well if the training data distribution differs significantly from the deployment data distribution."
        }
      ],
      "sampleClaims": [
        {
          "text": "The medical imaging dataset's coverage is characterised by both typical tissue patterns and rare pathological presentations requiring specialised attention",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The credit model's validation set includes both representative borrower profiles and exceptional cases that deviate from standard lending patterns",
          "domain": "finance",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The environmental monitoring system's training data reflects both common measurement conditions and unusual scenarios that test operational boundaries",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The hiring dataset's representative candidates do not systematically exclude particular demographic groups whilst edge cases disproportionately represent minorities",
          "domain": "public sector",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The system's performance on atypical cases is documented alongside its behaviour on prototypical examples",
          "domain": "general",
          "assuranceGoal": "fairness"
        }
      ]
    },
    {
      "@id": "tea:technique/influence-functions",
      "@type": "Technique",
      "name": "Influence Functions",
      "slug": "influence-functions",
      "description": "Influence functions quantify how much each training example influenced a model's predictions by computing the change in prediction that would occur if that training example were removed and the model retrained. Using calculus and the implicit function theorem, they approximate this 'leave-one-out' effect without actually retraining the model by computing gradients and Hessian information. This mathematical approach reveals which specific training examples were most responsible for pushing the model toward or away from particular predictions, enabling practitioners to trace problematic outputs back to their root causes in the training data.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/fairness",
        "tea:goal/privacy"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/linear-models",
        "tea:tag/applicable-models/architecture/neural-networks",
        "tea:tag/applicable-models/paradigm/parametric",
        "tea:tag/applicable-models/paradigm/supervised",
        "tea:tag/applicable-models/requirements/differentiable",
        "tea:tag/applicable-models/requirements/gradient-access",
        "tea:tag/applicable-models/requirements/training-data",
        "tea:tag/applicable-models/requirements/white-box",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/attribution-methods/gradient-based",
        "tea:tag/assurance-goal-category/explainability/explains/causal-pathways",
        "tea:tag/assurance-goal-category/explainability/explains/data-patterns",
        "tea:tag/assurance-goal-category/explainability/instance-based/influence-analysis",
        "tea:tag/assurance-goal-category/explainability/property/causality",
        "tea:tag/assurance-goal-category/explainability/property/fidelity",
        "tea:tag/assurance-goal-category/fairness",
        "tea:tag/assurance-goal-category/privacy",
        "tea:tag/data-requirements/access-to-training-data",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/explanatory-scope/local",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "complexityRating": 5,
      "computationalCostRating": 5,
      "relatedTo": [
        "tea:technique/jackknife-resampling",
        "tea:technique/integrated-gradients",
        "tea:technique/machine-unlearning",
        "tea:technique/data-poisoning-detection"
      ],
      "citesResource": [
        "tea:resource/weikohUnderstandingBlackboxPredictions2017",
        "tea:resource/nimarbPytorch_influence_functions2019",
        "tea:resource/keunchoeWhatYourData2024",
        "tea:resource/schioppaScalingInfluenceFunctions2021",
        "tea:resource/torch-influencedevelopersWelcomeTorchinfluencesAPI2023"
      ],
      "exampleUseCases": [
        {
          "description": "Investigating why a medical diagnosis model misclassified a patient by identifying which specific training cases most influenced the incorrect prediction, revealing potential mislabelled examples or problematic patterns in the training data.",
          "goal": "Explainability"
        },
        {
          "description": "Analysing a spam detection system that falsely flagged legitimate emails by tracing the prediction back to influential training examples, discovering that certain training emails contained misleading patterns that caused the model to overfit.",
          "goal": "Explainability"
        },
        {
          "description": "Auditing a loan approval model for discriminatory patterns by identifying which training examples most influenced rejections of minority applicants, revealing whether biased historical decisions are driving current unfair outcomes.",
          "goal": "Fairness"
        },
        {
          "description": "Assessing membership inference risks in a medical model by identifying whether certain patient records have disproportionate influence on predictions, indicating potential data leakage vulnerabilities.",
          "goal": "Privacy"
        }
      ],
      "limitations": [
        {
          "description": "Computationally intensive, requiring Hessian matrix computations that become intractable for very large models with millions of parameters."
        },
        {
          "description": "Requires access to the complete training dataset and training process, making it impossible to apply to pre-trained models without access to original training data."
        },
        {
          "description": "Accuracy degrades for highly non-convex models where the linear approximation underlying influence functions breaks down."
        },
        {
          "description": "Results can be sensitive to hyperparameter choices and may not generalise well across different model architectures or training procedures."
        }
      ],
      "sampleClaims": [
        {
          "text": "The diagnostic model's predictions are traceable to specific patient cases in the training data",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The credit model's decisions on individual applications are attributable to identifiable historical loan records",
          "domain": "finance",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The welfare eligibility system's rejections can be traced to specific training cases to identify discriminatory patterns",
          "domain": "public sector",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The medical model's predictions reveal which patient records from the training set had disproportionate influence on diagnostic outputs",
          "domain": "healthcare",
          "assuranceGoal": "privacy"
        },
        {
          "text": "The perception system's object classification decisions are traceable to specific labeled examples from the training corpus",
          "domain": "autonomous systems",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/contrastive-explanation-method",
      "@type": "Technique",
      "name": "Contrastive Explanation Method",
      "slug": "contrastive-explanation-method",
      "description": "The Contrastive Explanation Method (CEM) explains model decisions by generating contrastive examples that reveal what makes a prediction distinctive. It identifies 'pertinent negatives' (minimal features that could be removed to change the prediction) and 'pertinent positives' (minimal features that must be present to maintain the prediction). This approach helps users understand not just what led to a decision, but what would need to change to achieve a different outcome, providing actionable insights for decision-making.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/transparency"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/neural-networks",
        "tea:tag/applicable-models/paradigm/discriminative",
        "tea:tag/applicable-models/paradigm/supervised",
        "tea:tag/applicable-models/requirements/differentiable",
        "tea:tag/applicable-models/requirements/gradient-access",
        "tea:tag/applicable-models/requirements/white-box",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/attribution-methods/perturbation-based",
        "tea:tag/assurance-goal-category/explainability/explains/decision-boundaries",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/instance-based/counterfactual",
        "tea:tag/assurance-goal-category/explainability/property/comprehensibility",
        "tea:tag/assurance-goal-category/explainability/property/counterfactual-validity",
        "tea:tag/assurance-goal-category/explainability/property/sparsity",
        "tea:tag/assurance-goal-category/transparency",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/explanatory-scope/local",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "acronym": "CEM",
      "complexityRating": 5,
      "computationalCostRating": 4,
      "relatedTo": [
        "tea:technique/local-interpretable-model-agnostic-explanations",
        "tea:technique/anchor",
        "tea:technique/integrated-gradients",
        "tea:technique/shapley-additive-explanations"
      ],
      "citesResource": [
        "tea:resource/dhurandharExplanationsBasedMissing2018",
        "tea:resource/InterpretableMachineLearning2019a",
        "tea:resource/francescoBenchmarkingSurveyExplanation2023"
      ],
      "exampleUseCases": [
        {
          "description": "Explaining loan application rejections by showing that removing recent late payments (pertinent negative) or adding £5,000 more annual income (pertinent positive) would change the decision to approval, giving applicants clear actionable guidance.",
          "goal": "Explainability"
        },
        {
          "description": "Analysing medical diagnosis models by identifying that removing a specific symptom combination would change a high-risk classification to low-risk, helping clinicians understand the critical diagnostic factors.",
          "goal": "Explainability"
        },
        {
          "description": "Providing transparent hiring decisions by showing job candidates exactly which qualifications (pertinent positives) they need to acquire or which application elements (pertinent negatives) might be hindering their success.",
          "goal": "Transparency"
        }
      ],
      "limitations": [
        {
          "description": "Computationally expensive as it requires solving an optimisation problem for each individual instance to find minimal perturbations."
        },
        {
          "description": "Results can be highly sensitive to hyperparameter settings, requiring careful tuning to produce meaningful explanations."
        },
        {
          "description": "May generate unrealistic or impossible contrastive examples if constraints are not properly specified, leading to impractical recommendations."
        },
        {
          "description": "Limited to scenarios where feature perturbations are meaningful and actionable, making it less suitable for immutable characteristics or highly constrained domains."
        }
      ],
      "sampleClaims": [
        {
          "text": "The model's decision rationale identifies both what features must be present to maintain the current prediction and what features could be removed to change it",
          "domain": "general",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The loan application system communicates to applicants the minimal changes needed to reverse a rejection decision",
          "domain": "finance",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The diagnostic model explains high-risk classifications by identifying which symptom combinations, if absent, would result in a low-risk assessment",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The hiring system provides candidates with actionable feedback specifying which qualifications are sufficient for selection and which deficiencies drive rejection",
          "domain": "public sector",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The fraud detection model distinguishes between transactions by showing what transaction attributes would need to be different to flip the fraud classification",
          "domain": "finance",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/anchor",
      "@type": "Technique",
      "name": "ANCHOR",
      "slug": "anchor",
      "description": "ANCHOR generates high-precision if-then rules that explain individual predictions by identifying the minimal set of feature conditions that guarantee a specific prediction with high confidence. It searches for 'anchor' conditions (e.g., 'age > 30 AND income < £50k') that ensure the model gives the same prediction at least 95% of the time when those conditions are met. This creates human-readable rules that users can trust as sufficient conditions for understanding why a particular decision was made.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/transparency"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/explains/decision-boundaries",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/property/comprehensibility",
        "tea:tag/assurance-goal-category/explainability/property/fidelity",
        "tea:tag/assurance-goal-category/explainability/property/sparsity",
        "tea:tag/assurance-goal-category/explainability/surrogate-models/rule-extraction",
        "tea:tag/assurance-goal-category/transparency",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/statistics",
        "tea:tag/explanatory-scope/local",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "acronym": "ANCHOR",
      "complexityRating": 3,
      "computationalCostRating": 3,
      "relatedTo": [
        "tea:technique/local-interpretable-model-agnostic-explanations",
        "tea:technique/shapley-additive-explanations",
        "tea:technique/rulefit",
        "tea:technique/ridge-regression-surrogates"
      ],
      "citesResource": [
        "tea:resource/ribeiroAnchorsHighPrecisionModelAgnostic2018",
        "tea:resource/marcotcrAnchor2018",
        "tea:resource/seldonioAlibi2019",
        "tea:resource/InterpretableMachineLearning2019b"
      ],
      "exampleUseCases": [
        {
          "description": "Explaining loan application decisions with rules like 'IF credit_score > 650 AND debt_ratio < 0.4 THEN approval = 95% likely', giving applicants clear, actionable conditions they can understand and potentially improve.",
          "goal": "Explainability"
        },
        {
          "description": "Generating diagnostic rules for medical predictions such as 'IF fever > 38.5°C AND white_blood_cells > 12,000 THEN infection = 92% likely', helping clinicians validate automated diagnoses with trusted clinical indicators.",
          "goal": "Explainability"
        },
        {
          "description": "Creating transparent hiring decisions with rules like 'IF experience >= 3_years AND degree = relevant THEN hire = 89% likely', providing clear justification for recruitment decisions that can be audited for fairness.",
          "goal": "Transparency"
        }
      ],
      "limitations": [
        {
          "description": "Limited to local explanations for individual instances, cannot provide global insights about overall model behaviour."
        },
        {
          "description": "Requires discretisation of continuous features, which can lose important nuanced information and create arbitrary thresholds."
        },
        {
          "description": "May fail to find suitable anchor rules if precision requirements are too strict or if the prediction space is highly complex."
        },
        {
          "description": "Computationally expensive as it requires extensive sampling to validate rule precision, especially for high-dimensional data."
        }
      ],
      "sampleClaims": [
        {
          "text": "The model's individual predictions are supported by verifiable sufficient conditions with quantified confidence guarantees",
          "domain": "general",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The lending system provides loan applicants with specific, actionable conditions that guarantee approval with stated probability",
          "domain": "finance",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The diagnostic system's recommendations are justified by minimal sets of clinical indicators that ensure the decision under specified conditions",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The hiring decision criteria are documented as precise if-then rules with empirically validated confidence bounds",
          "domain": "public sector",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The fraud detection system identifies sufficient feature combinations that reliably predict flagged transactions with quantified precision",
          "domain": "finance",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/rulefit",
      "@type": "Technique",
      "name": "RuleFit",
      "slug": "rulefit",
      "description": "RuleFit creates interpretable surrogate models that can explain complex black-box models or serve as interpretable alternatives. It works by learning a sparse linear model that combines automatically extracted decision rules with original features. The technique first builds tree ensembles to generate candidate rules, then uses LASSO regression to select the most important rules and features. The resulting model provides global explanations through human-readable rules (e.g., 'IF age > 50 AND income < 30k THEN ...') combined with linear feature weights, making complex model behaviour transparent and auditable.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/transparency"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/paradigm/supervised",
        "tea:tag/applicable-models/requirements/training-data",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/explains/decision-boundaries",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/property/comprehensibility",
        "tea:tag/assurance-goal-category/explainability/property/fidelity",
        "tea:tag/assurance-goal-category/explainability/property/sparsity",
        "tea:tag/assurance-goal-category/explainability/surrogate-models/global-surrogates",
        "tea:tag/assurance-goal-category/explainability/surrogate-models/rule-extraction",
        "tea:tag/assurance-goal-category/transparency",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/statistics",
        "tea:tag/explanatory-scope/global",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "complexityRating": 3,
      "computationalCostRating": 3,
      "relatedTo": [
        "tea:technique/ridge-regression-surrogates",
        "tea:technique/anchor",
        "tea:technique/local-interpretable-model-agnostic-explanations",
        "tea:technique/mean-decrease-impurity"
      ],
      "citesResource": [
        "tea:resource/christophmRulefit2015",
        "tea:resource/nalenzTreeEnsemblesRule2017",
        "tea:resource/katoSafeRuleFitLearning2018",
        "tea:resource/csinvaImodels2019",
        "tea:resource/whortonGettingMoreRegression2020"
      ],
      "exampleUseCases": [
        {
          "description": "Building customer churn prediction models with rules like 'IF contract_length < 12_months AND support_calls > 5 THEN churn_risk = high', allowing marketing teams to understand and act on the key drivers of customer attrition.",
          "goal": "Explainability"
        },
        {
          "description": "Creating credit scoring models that combine traditional linear factors (income, age) with interpretable rules (IF recent_missed_payments = 0 AND account_age > 2_years THEN creditworthy), providing transparent lending decisions.",
          "goal": "Explainability"
        },
        {
          "description": "Developing regulatory-compliant medical diagnosis models where treatment recommendations combine clinical measurements with clear decision rules (IF blood_pressure > 140 AND diabetes = true THEN high_risk), enabling audit trails for healthcare decisions.",
          "goal": "Transparency"
        }
      ],
      "limitations": [
        {
          "description": "Can generate large numbers of rules even with regularisation, potentially overwhelming users and reducing practical interpretability."
        },
        {
          "description": "Performance may be inferior to complex ensemble methods when rule complexity is constrained for interpretability."
        },
        {
          "description": "Rule extraction quality depends heavily on the underlying tree ensemble, which may miss important feature interactions if not properly configured."
        },
        {
          "description": "Requires careful hyperparameter tuning to balance between model complexity and interpretability, with no universal optimal setting."
        }
      ],
      "sampleClaims": [
        {
          "text": "The credit risk model's decision logic is expressible as a sparse set of interpretable if-then rules combined with linear feature weights",
          "domain": "finance",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The patient risk stratification system's predictions are traceable to explicit clinical decision rules that mirror diagnostic reasoning patterns",
          "domain": "healthcare",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The fraud detection model identifies risk through comprehensible rules that stakeholders can validate against domain knowledge",
          "domain": "finance",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The customer churn prediction system's global behavior is approximated by a small number of actionable business rules rather than opaque feature interactions",
          "domain": "general",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The regulatory compliance model combines human-readable decision boundaries with weighted factors in a single auditable representation",
          "domain": "public sector",
          "assuranceGoal": "transparency"
        }
      ]
    },
    {
      "@id": "tea:technique/monte-carlo-dropout",
      "@type": "Technique",
      "name": "Monte Carlo Dropout",
      "slug": "monte-carlo-dropout",
      "description": "Monte Carlo Dropout estimates prediction uncertainty by applying dropout (randomly setting neural network weights to zero) during inference rather than just training. It performs multiple forward passes through the network with different random dropout patterns and collects the resulting predictions to form a distribution. Low variance across predictions indicates epistemic certainty (the model is confident), while high variance suggests epistemic uncertainty (the model is unsure). This technique transforms any dropout-trained neural network into a Bayesian approximation for uncertainty quantification.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/reliability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/neural-networks",
        "tea:tag/applicable-models/paradigm/probabilistic",
        "tea:tag/applicable-models/paradigm/supervised",
        "tea:tag/applicable-models/requirements/architecture-specific",
        "tea:tag/applicable-models/requirements/model-internals",
        "tea:tag/applicable-models/requirements/probabilistic-output",
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/explains/prediction-confidence",
        "tea:tag/assurance-goal-category/explainability/property/consistency",
        "tea:tag/assurance-goal-category/explainability/property/efficiency",
        "tea:tag/assurance-goal-category/explainability/uncertainty-analysis/prediction-uncertainty",
        "tea:tag/assurance-goal-category/reliability",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/expertise-needed/statistics",
        "tea:tag/explanatory-scope/global",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/lifecycle-stage/system-deployment-and-use",
        "tea:tag/technique-type/algorithmic"
      ],
      "complexityRating": 3,
      "computationalCostRating": 3,
      "relatedTo": [
        "tea:technique/deep-ensembles",
        "tea:technique/conformal-prediction",
        "tea:technique/out-of-distribution-detector-for-neural-networks",
        "tea:technique/prediction-intervals"
      ],
      "citesResource": [
        "tea:resource/galDropoutBayesianApproximation2015",
        "tea:resource/mattiaseguUncertainty_estimation_deep_learning2019",
        "tea:resource/uzh-rpgDeep_uncertainty_estimation2020",
        "tea:resource/farhadulislamHowCertainAre2023"
      ],
      "exampleUseCases": [
        {
          "description": "Quantifying diagnostic uncertainty in medical imaging models by running 50+ Monte Carlo forward passes to detect when a chest X-ray classification is highly uncertain, prompting radiologist review for borderline cases.",
          "goal": "Reliability"
        },
        {
          "description": "Estimating prediction confidence in autonomous vehicle perception systems, where high uncertainty in object detection (e.g., variance > 0.3 across MC samples) triggers more conservative driving behaviour or human handover.",
          "goal": "Reliability"
        },
        {
          "description": "Providing uncertainty estimates in financial fraud detection models, where high epistemic uncertainty (wide prediction variance) indicates the model lacks sufficient training data for similar transaction patterns, requiring manual review.",
          "goal": "Explainability"
        }
      ],
      "limitations": [
        {
          "description": "Only captures epistemic (model) uncertainty, not aleatoric (data) uncertainty, providing an incomplete picture of total prediction uncertainty."
        },
        {
          "description": "Computationally expensive as it requires multiple forward passes (typically 50-100) for each prediction, significantly increasing inference time."
        },
        {
          "description": "Results depend critically on dropout rate matching the training configuration, and poorly calibrated dropout can lead to misleading uncertainty estimates."
        },
        {
          "description": "Approximation quality varies with network architecture and dropout placement, with some configurations providing poor uncertainty calibration despite theoretical foundations."
        }
      ],
      "sampleClaims": [
        {
          "text": "The medical imaging system's prediction variance across repeated inference passes indicates epistemic uncertainty in borderline diagnostic cases",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The autonomous vehicle's object detection model quantifies prediction uncertainty without requiring multiple separately trained networks",
          "domain": "autonomous systems",
          "assuranceGoal": "reliability"
        },
        {
          "text": "The fraud detection system identifies transactions where the model lacks sufficient training data coverage through elevated prediction variance",
          "domain": "finance",
          "assuranceGoal": "reliability"
        },
        {
          "text": "The model's confidence estimates reflect genuine uncertainty in its learned parameters rather than data noise",
          "domain": "general",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The environmental forecasting model's prediction distributions reveal when operating conditions lie outside the model's epistemic envelope",
          "domain": "environmental",
          "assuranceGoal": "reliability"
        }
      ]
    },
    {
      "@id": "tea:technique/out-of-distribution-detector-for-neural-networks",
      "@type": "Technique",
      "name": "Out-of-Distribution Detector for Neural Networks",
      "slug": "out-of-distribution-detector-for-neural-networks",
      "description": "ODIN (Out-of-Distribution Detector for Neural Networks) identifies when a neural network encounters inputs significantly different from its training distribution. It enhances detection by applying temperature scaling to soften the model's output distribution and adding small, carefully calibrated perturbations to the input that push in-distribution samples towards higher confidence predictions. By measuring the maximum softmax probability after these adjustments, ODIN can effectively distinguish between in-distribution and out-of-distribution inputs, flagging potentially unreliable predictions before they cause downstream errors.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/reliability",
        "tea:goal/safety"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/neural-networks",
        "tea:tag/applicable-models/paradigm/discriminative",
