    {
      "@id": "tea:resource/transparentaidevelopersWelcomeTransparentAIsDocumentation2023",
      "@type": "Resource",
      "name": "Welcome to TransparentAI's documentation! — TransparentAI 0.1.0 ...",
      "citationKey": "transparentaidevelopersWelcomeTransparentAIsDocumentation2023",
      "url": "https://transparentai.readthedocs.io/en/latest",
