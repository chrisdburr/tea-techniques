{
  "name": "tea-techniques-mcp",
  "version": "1.0.0",
  "description": "MCP server for the TEA Techniques knowledge graph",
  "type": "module",
  "bin": {
    "tea-techniques-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "merge-claims": "tsx scripts/merge-claims.ts",
    "validate-claims": "tsx scripts/validate-claims.ts",
    "evaluate-cardiac-dt": "tsx scripts/evaluate-cardiac-dt.ts",
    "embedding-spike": "tsx scripts/embedding-spike.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "fuse.js": "^7.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@types/node": "^20",
    "onnxruntime-node": "^1.24.1",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
