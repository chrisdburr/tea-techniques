        "tea:tag/expertise-needed/software-engineering",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/lifecycle-stage/system-deployment-and-use",
        "tea:tag/technique-type/process"
      ],
      "complexityRating": 2,
      "computationalCostRating": 2,
      "relatedTo": [
        "tea:technique/model-development-audit-trails",
        "tea:technique/data-version-control",
        "tea:technique/automated-documentation-generation",
