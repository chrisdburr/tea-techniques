      "sourceType": "technical_paper",
      "authors": [
        "Bodria Francesco",
        "Giannotti Fosca",
        "Guidotti R.",
        "Naretto Francesca",
        "Pedreschi Dino",
        "Rinzivillo S."
      ],
      "publicationDate": "2023-01-01"
    },
    {
      "@id": "tea:resource/ribeiroAnchorsHighPrecisionModelAgnostic2018",
      "@type": "Resource",
      "name": "Anchors: High-Precision Model-Agnostic Explanations",
      "citationKey": "ribeiroAnchorsHighPrecisionModelAgnostic2018",
      "url": "https://homes.cs.washington.edu/~marcotcr/aaai18.pdf",
      "sourceType": "technical_paper",
      "authors": [
        "Marco Tulio Ribeiro",
        "Sameer Singh",
