      "@id": "tea:resource/aif360developersAif360sklearnmetricsequal_opportunity_differenceAif3600612018",
      "@type": "Resource",
      "name": "aif360.sklearn.metrics.equal_opportunity_difference — aif360 0.6.1 ...",
