    {
      "@id": "tea:technique/calibration-with-equality-of-opportunity",
      "@type": "Technique",
      "name": "Calibration with Equality of Opportunity",
      "slug": "calibration-with-equality-of-opportunity",
      "description": "A post-processing fairness technique that adjusts model predictions to achieve equal true positive rates across protected groups whilst maintaining calibration within each group. The method addresses fairness by ensuring that qualified individuals from different demographic groups have equal chances of receiving positive predictions, whilst preserving the meaning of probability scores within each group. This technique attempts to balance the competing objectives of group fairness and accurate probability estimation.",
      "addressesGoal": [
        "tea:goal/fairness",
        "tea:goal/transparency",
        "tea:goal/reliability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/paradigm/supervised",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/applicable-models/requirements/probabilistic-output",
        "tea:tag/assurance-goal-category/fairness",
        "tea:tag/assurance-goal-category/fairness/group",
        "tea:tag/assurance-goal-category/reliability",
        "tea:tag/assurance-goal-category/transparency",
        "tea:tag/data-requirements/calibration-set",
        "tea:tag/data-requirements/labelled-data",
        "tea:tag/data-requirements/sensitive-attributes",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/fairness-metric",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/expertise-needed/statistics",
        "tea:tag/fairness-approach/group",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/lifecycle-stage/model-development/testing",
        "tea:tag/technique-type/algorithmic"
      ],
      "complexityRating": 4,
      "computationalCostRating": 2,
      "relatedTo": [
        "tea:technique/equalised-odds-post-processing",
        "tea:technique/reject-option-classification",
        "tea:technique/threshold-optimiser",
        "tea:technique/out-of-domain-detection"
      ],
      "citesResource": [
        "tea:resource/pleissFairnessCalibration2017",
        "tea:resource/gpleissEqualized_odds_and_calibration2017",
        "tea:resource/hardtEqualityOpportunitySupervised2016",
        "tea:resource/fairlearndevelopersFairlearnPostprocessingMethods2018"
      ],
      "exampleUseCases": [
        {
          "description": "Adjusting a loan approval model to ensure that qualified applicants from different ethnic backgrounds have equal approval rates, whilst maintaining that a 70% predicted repayment probability means the same thing for each ethnic group in practice.",
          "goal": "Fairness"
        },
        {
          "description": "Post-processing a university admissions algorithm to equalise acceptance rates for qualified students across gender groups, whilst ensuring the predicted success scores remain well-calibrated within each gender to support transparent decision-making.",
          "goal": "Transparency"
        },
        {
          "description": "Calibrating a medical diagnosis model to maintain equal detection rates for a disease across different age groups whilst preserving the reliability of risk scores, ensuring that a 30% risk prediction accurately reflects actual disease occurrence within each age group.",
          "goal": "Reliability"
        }
      ],
      "limitations": [
        {
          "description": "Fundamental mathematical incompatibility exists between perfect calibration and exact equality of opportunity, except in highly constrained special cases."
        },
        {
          "description": "May reduce overall model accuracy or calibration when forcing equal true positive rates across groups with genuinely different base rates."
        },
        {
          "description": "Requires access to sensitive attributes during post-processing, which may not be available or legally permissible in all contexts."
        },
        {
          "description": "The technique only addresses one aspect of fairness (true positive rates) and may allow disparities in false positive rates between groups."
        },
        {
          "description": "Post-processing approaches cannot address biases inherent in the training data or model architecture, only adjust final predictions."
        }
      ],
      "sampleClaims": [
        {
          "text": "The lending system ensures qualified applicants from different demographic groups receive positive outcomes at equal rates whilst probability scores retain consistent meaning within each group",
          "domain": "finance",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The diagnostic model achieves equal detection rates for the condition across patient populations whilst maintaining that a given risk score reflects the same actual disease probability within each population",
          "domain": "healthcare",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The system's probability estimates remain interpretable and well-calibrated within each demographic group after adjusting for equal opportunity",
          "domain": "public sector",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The model's confidence scores accurately reflect true outcome rates within each demographic segment despite equalising true positive rates across segments",
          "domain": "healthcare",
          "assuranceGoal": "reliability"
        },
        {
          "text": "The system provides equally qualified individuals from all protected groups with equivalent likelihood of favourable classification",
          "domain": "general",
          "assuranceGoal": "fairness"
        }
      ]
    },
    {
      "@id": "tea:technique/equal-opportunity-difference",
      "@type": "Technique",
      "name": "Equal Opportunity Difference",
      "slug": "equal-opportunity-difference",
      "description": "A fairness metric that quantifies discrimination by measuring the difference in true positive rates (recall) between protected and privileged groups. Based on Hardt et al.'s equality of opportunity framework, this metric computes the maximum difference in TPR across demographic groups, with a value of 0 indicating perfect fairness. The technique provides a mathematical measure of whether qualified individuals from different groups have equal chances of receiving positive predictions.",
      "addressesGoal": [
        "tea:goal/fairness",
        "tea:goal/transparency",
        "tea:goal/reliability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/paradigm/supervised",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/fairness",
        "tea:tag/assurance-goal-category/fairness/group",
        "tea:tag/assurance-goal-category/reliability",
        "tea:tag/assurance-goal-category/transparency",
        "tea:tag/data-requirements/labelled-data",
        "tea:tag/data-requirements/sensitive-attributes",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/fairness-metric",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/low",
        "tea:tag/fairness-approach/group",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/lifecycle-stage/model-development/testing",
        "tea:tag/lifecycle-stage/system-deployment-and-use/monitoring",
        "tea:tag/technique-type/metric"
      ],
      "complexityRating": 2,
      "computationalCostRating": 1,
      "relatedTo": [
        "tea:technique/demographic-parity-assessment",
        "tea:technique/average-odds-difference",
        "tea:technique/attribute-removal-fairness-through-unawareness",
        "tea:technique/calibration-with-equality-of-opportunity"
      ],
      "citesResource": [
        "tea:resource/aif360developersAif360sklearnmetricsequal_opportunity_differenceAif3600612018",
        "tea:resource/transparentaidevelopersWelcomeTransparentAIsDocumentation2023",
        "tea:resource/laledevelopersLalelibaif360utilModuleLALE2024",
        "tea:resource/ibmBiasmitigationofmachinelearningmodelsusingaif3602020",
        "tea:resource/aif360developersAif360algorithmspostprocessingRejectOptionClassification2018"
      ],
      "exampleUseCases": [
        {
          "description": "Evaluating a loan approval model to ensure that qualified applicants from different ethnic backgrounds have equal approval rates, measuring whether a 90% TPR for qualified white applicants is matched by similar rates for qualified minority applicants.",
          "goal": "Fairness"
        },
        {
          "description": "Auditing a medical diagnosis system to verify that patients with a particular condition are detected at equal rates across age groups, providing transparent evidence that diagnostic accuracy is consistent regardless of patient demographics.",
          "goal": "Transparency"
        },
        {
          "description": "Monitoring a university admissions algorithm in production to ensure that qualified students from different socioeconomic backgrounds have equal acceptance rates, validating the reliability of the fairness properties over time.",
          "goal": "Reliability"
        }
      ],
      "limitations": [
        {
          "description": "Only considers true positive rates and ignores false positive rate disparities, potentially allowing discrimination in the form of unequal false alarm rates between groups."
        },
        {
          "description": "Requires accurate ground truth labels for the positive class, which may be biased or unavailable in some domains."
        },
        {
          "description": "Improving TPR for one group might increase FPR for that group, creating trade-offs between different types of fairness."
        },
        {
          "description": "Does not account for intersectional fairness across multiple protected attributes simultaneously."
        },
        {
          "description": "May not capture fairness concerns for the negative class or individuals who should not receive positive predictions."
        }
      ],
      "sampleClaims": [
        {
          "text": "The hiring system identifies qualified candidates at equivalent rates across demographic groups",
          "domain": "general",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The diagnostic model detects disease in affected patients consistently regardless of patient ethnicity",
          "domain": "healthcare",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The lending model's approval rate for creditworthy applicants does not vary by protected demographic attributes",
          "domain": "finance",
          "assuranceGoal": "reliability"
        },
        {
          "text": "The benefit allocation system's true positive rate disparity across demographic groups is documented and monitored",
          "domain": "public sector",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The model's ability to correctly identify qualified individuals is measured separately for each protected group",
          "domain": "general",
          "assuranceGoal": "transparency"
        }
      ]
    },
    {
      "@id": "tea:technique/average-odds-difference",
      "@type": "Technique",
      "name": "Average Odds Difference",
      "slug": "average-odds-difference",
      "description": "Average Odds Difference measures fairness by calculating the average difference in both false positive rates and true positive rates between different demographic groups. This metric captures how consistently a model performs across groups for both positive and negative predictions. A value of 0 indicates perfect fairness under the equalized odds criterion, while larger absolute values indicate greater disparities in model performance between groups.",
      "addressesGoal": [
        "tea:goal/fairness",
        "tea:goal/reliability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/paradigm/supervised",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/fairness",
        "tea:tag/assurance-goal-category/reliability",
        "tea:tag/data-requirements/sensitive-attributes",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/low",
        "tea:tag/fairness-approach/group",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/lifecycle-stage/testing",
        "tea:tag/technique-type/metric"
      ],
      "complexityRating": 2,
      "computationalCostRating": 1,
      "relatedTo": [
        "tea:technique/demographic-parity-assessment",
        "tea:technique/equal-opportunity-difference",
        "tea:technique/attribute-removal-fairness-through-unawareness",
        "tea:technique/calibration-with-equality-of-opportunity"
      ],
      "citesResource": [
        "tea:resource/hardtEqualityOpportunitySupervised2016",
        "tea:resource/yuFairBalanceHowAchieve2021",
        "tea:resource/aif360developersAIF360AverageOdds2018",
        "tea:resource/fairlearnFairlearn2018"
      ],
      "exampleUseCases": [
        {
          "description": "Evaluating criminal risk assessment tools to ensure equal false positive rates (wrongly flagging low-risk individuals as high-risk) and true positive rates (correctly identifying high-risk individuals) across racial and ethnic groups.",
          "goal": "Fairness"
        },
        {
          "description": "Auditing hiring algorithms to verify that both the rate of correctly identifying qualified candidates and the rate of incorrectly rejecting qualified candidates remain consistent across gender and demographic groups.",
          "goal": "Fairness"
        },
        {
          "description": "Monitoring loan approval systems to ensure reliable performance by checking that both approval rates for creditworthy applicants and rejection rates for non-creditworthy applicants are consistent across protected demographic categories.",
          "goal": "Reliability"
        },
        {
          "description": "Testing medical diagnostic models to validate that diagnostic accuracy (both correctly identifying disease and correctly ruling out disease) remains consistent across patient demographics, ensuring reliable healthcare delivery.",
          "goal": "Reliability"
        }
      ],
      "limitations": [
        {
          "description": "Averaging effect can mask important disparities when false positive and true positive rate differences compensate for each other, potentially hiding significant bias in one direction."
        },
        {
          "description": "Requires access to ground truth labels and sensitive attribute information, which may not be available in all deployment scenarios or may be subject to privacy constraints."
        },
        {
          "description": "Does not account for base rate differences between groups, meaning equal error rates may not translate to equal treatment when group prevalences differ significantly."
        },
        {
          "description": "Focuses solely on prediction accuracy disparities without considering whether the underlying decision-making process or feature selection introduces systematic bias against certain groups."
        },
        {
          "description": "May encourage optimization for fairness metrics at the expense of overall model performance, potentially reducing utility for the primary prediction task."
        }
      ],
      "sampleClaims": [
        {
          "text": "The criminal risk assessment system maintains equivalent error rates for both false alarms and correct identifications across racial and ethnic groups",
          "domain": "public sector",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The hiring model's accuracy in both accepting qualified candidates and rejecting unqualified candidates is consistent across all protected demographic categories",
          "domain": "general",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The medical diagnostic system demonstrates balanced performance across patient demographics for both correctly identifying disease presence and correctly ruling out disease absence",
          "domain": "healthcare",
          "assuranceGoal": "reliability"
        },
        {
          "text": "The credit scoring model's true approval rate for creditworthy applicants and false approval rate for non-creditworthy applicants remain equitable across protected groups",
          "domain": "finance",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The fraud detection system maintains consistent detection accuracy and false alarm rates across customer segments regardless of demographic characteristics",
          "domain": "finance",
          "assuranceGoal": "reliability"
        }
      ]
    },
    {
      "@id": "tea:technique/path-specific-counterfactual-fairness-assessment",
      "@type": "Technique",
      "name": "Path-Specific Counterfactual Fairness Assessment",
      "slug": "path-specific-counterfactual-fairness-assessment",
      "description": "A causal fairness evaluation technique that assesses algorithmic discrimination by examining specific causal pathways in a model's decision-making process. Unlike general counterfactual fairness, this approach enables practitioners to identify and intervene on particular causal paths that may introduce bias whilst preserving other legitimate pathways. The method uses causal graphs to distinguish between direct discrimination (through protected attributes) and indirect discrimination (through seemingly neutral factors that correlate with protected attributes), allowing for more nuanced fairness assessments in complex causal settings.",
      "addressesGoal": [
        "tea:goal/fairness",
        "tea:goal/transparency",
        "tea:goal/reliability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/paradigm/supervised",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/fairness",
        "tea:tag/assurance-goal-category/fairness/causal",
        "tea:tag/assurance-goal-category/reliability",
        "tea:tag/assurance-goal-category/transparency",
        "tea:tag/data-requirements/causal-graph",
        "tea:tag/data-requirements/sensitive-attributes",
        "tea:tag/data-type/tabular",
        "tea:tag/evidence-type/causal-analysis",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/causal-inference",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/expertise-needed/statistics",
        "tea:tag/fairness-approach/causal",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/lifecycle-stage/model-evaluation",
        "tea:tag/technique-type/metric"
      ],
      "complexityRating": 5,
      "computationalCostRating": 4,
      "relatedTo": [
        "tea:technique/counterfactual-fairness-assessment",
        "tea:technique/average-odds-difference",
        "tea:technique/equal-opportunity-difference",
        "tea:technique/area-under-precision-recall-curve"
      ],
      "citesResource": [
        "tea:resource/hatanoPathSpecificCounterfactualFairness2025"
      ],
      "exampleUseCases": [
        {
          "description": "Evaluating hiring algorithms by identifying which causal pathways from education and experience legitimately affect job performance versus those that introduce gender or racial bias, enabling targeted interventions that preserve merit-based selection whilst eliminating discriminatory pathways.",
          "goal": "Fairness"
        },
        {
          "description": "Analysing loan approval models to provide transparent evidence of which factors legitimately influence creditworthiness versus those that create indirect discrimination, enabling clear explanations to regulators about causal mechanisms underlying fair lending decisions.",
          "goal": "Transparency"
        },
        {
          "description": "Assessing medical diagnosis systems to ensure reliable performance by distinguishing between clinically relevant causal pathways (symptoms to diagnosis) and potentially biased pathways (demographics to diagnosis), maintaining diagnostic accuracy whilst preventing healthcare disparities.",
          "goal": "Reliability"
        }
      ],
      "limitations": [
        {
          "description": "Requires identifying which causal pathways are 'allowable' and which are not—a subjective decision; analyzing specific paths adds complexity to the causal model and the fairness criterion."
        }
      ],
      "sampleClaims": [
        {
          "text": "The hiring system's decisions are not influenced by gender through educational pathways whilst preserving the legitimate influence of qualifications on employment outcomes",
          "domain": "general",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The loan approval model's risk assessment isolates the direct influence of creditworthiness from indirect effects of demographic characteristics propagating through correlated factors",
          "domain": "finance",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The diagnostic system's predictions are attributable to specific clinical pathways independent of demographic factors that influence healthcare access",
          "domain": "healthcare",
          "assuranceGoal": "reliability"
        },
        {
          "text": "The decision process documents which factors legitimately affect outcomes versus those that create indirect discrimination through upstream correlations",
          "domain": "public sector",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The model's treatment recommendations remain consistent across patient demographics when controlling for symptom severity and medical history whilst allowing clinically relevant differences to influence care decisions",
          "domain": "healthcare",
          "assuranceGoal": "fairness"
        }
      ]
    },
    {
      "@id": "tea:technique/bayesian-fairness-regularization",
      "@type": "Technique",
      "name": "Bayesian Fairness Regularization",
      "slug": "bayesian-fairness-regularization",
      "description": "Bayesian Fairness Regularization incorporates fairness constraints into machine learning models through Bayesian methods, treating fairness as a prior distribution or regularization term. This approach includes techniques like Fair Bayesian Optimization that use constrained optimization to tune model hyperparameters whilst enforcing fairness constraints, and methods that add regularization terms to objective functions to penalize discriminatory predictions. The technique allows for probabilistic interpretation of fairness constraints and can account for uncertainty in both model parameters and fairness requirements.",
      "addressesGoal": [
        "tea:goal/fairness",
        "tea:goal/reliability"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/paradigm/parametric",
        "tea:tag/applicable-models/paradigm/supervised",
        "tea:tag/applicable-models/requirements/gradient-access",
        "tea:tag/applicable-models/requirements/training-data",
        "tea:tag/applicable-models/requirements/white-box",
        "tea:tag/assurance-goal-category/fairness",
        "tea:tag/assurance-goal-category/reliability",
        "tea:tag/data-requirements/sensitive-attributes",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/expertise-needed/statistics",
        "tea:tag/fairness-approach/group",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/technique-type/algorithmic"
      ],
      "complexityRating": 5,
      "computationalCostRating": 4,
      "relatedTo": [
        "tea:technique/fairness-gan",
        "tea:technique/attribute-removal-fairness-through-unawareness",
        "tea:technique/sensitivity-analysis-for-fairness",
        "tea:technique/out-of-domain-detection"
      ],
      "citesResource": [
        "tea:resource/dimitrakakisBayesianFairness2017",
        "tea:resource/perroneFairBayesianOptimization2020",
        "tea:resource/ztanmlFgp2019",
        "tea:resource/kamishimaFairnessAwareClassifierPrejudice2012"
      ],
      "exampleUseCases": [
        {
          "description": "Using Fair Bayesian Optimization to tune hyperparameters of credit risk models, automatically balancing predictive accuracy with fairness constraints across different demographic groups whilst accounting for uncertainty in both model performance and fairness requirements.",
          "goal": "Fairness"
        },
        {
          "description": "Implementing Bayesian neural networks with fairness-aware priors for hiring recommendation systems, where uncertainty in fairness constraints is modeled probabilistically to ensure robust fair decision-making across different candidate populations.",
          "goal": "Fairness"
        },
        {
          "description": "Applying Bayesian regularization techniques to medical diagnosis models to ensure reliable performance across patient demographics, using probabilistic constraints to maintain consistent diagnostic accuracy whilst preventing algorithmic bias in healthcare delivery.",
          "goal": "Reliability"
        },
        {
          "description": "Developing insurance premium calculation models using Bayesian fairness regularization to ensure actuarially sound pricing that meets regulatory fairness requirements, with probabilistic modeling of both risk assessment accuracy and demographic equity.",
          "goal": "Fairness"
        }
      ],
      "limitations": [
        {
          "description": "Prior selection challenges make it difficult to specify appropriate prior distributions for fairness constraints, requiring domain expertise and potentially leading to suboptimal or biased outcomes if priors are poorly chosen."
        },
        {
          "description": "Computational complexity increases significantly due to Bayesian inference requirements, including sampling methods, variational inference, or optimization over probability distributions, making the approach less scalable for large datasets."
        },
        {
          "description": "Sensitivity to hyperparameters affects both the Bayesian inference process and fairness regularization terms, requiring careful tuning of multiple parameters that control the trade-off between accuracy, fairness, and computational efficiency."
        },
        {
          "description": "Convergence and stability issues may arise in Bayesian optimization with fairness constraints, particularly when fairness objectives conflict with performance objectives or when the constraint space becomes highly complex."
        },
        {
          "description": "Limited theoretical understanding exists for the interaction between Bayesian uncertainty quantification and fairness constraints, making it challenging to provide guarantees about both predictive performance and fairness under uncertainty."
        }
      ],
      "sampleClaims": [
        {
          "text": "The lending model's fairness guarantees account for uncertainty in both demographic data quality and group membership boundaries",
          "domain": "finance",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The hiring system's decisions balance predictive accuracy with equity constraints through probabilistically-weighted regularization",
          "domain": "general",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The diagnostic model maintains reliable performance across patient subgroups whilst incorporating uncertainty about demographic fairness requirements",
          "domain": "healthcare",
          "assuranceGoal": "reliability"
        },
        {
          "text": "The risk assessment model quantifies confidence in its fairness properties alongside prediction uncertainty",
          "domain": "finance",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The system's hyperparameters are optimized to meet fairness constraints whilst accounting for variability in model performance",
          "domain": "public sector",
          "assuranceGoal": "reliability"
        }
      ]
    },
    {
      "@id": "tea:technique/model-development-audit-trails",
      "@type": "Technique",
      "name": "Model Development Audit Trails",
      "slug": "model-development-audit-trails",
      "description": "Model development audit trails create comprehensive, immutable records of all decisions, experiments, and changes throughout the ML lifecycle. This technique captures dataset versions, training configurations, hyperparameter searches, model architecture changes, evaluation results, and deployment decisions in tamper-evident logs. Audit trails enable reproducibility, accountability, and regulatory compliance by documenting who made what changes when and why, supporting post-hoc investigation of model failures or unexpected behaviours.",
      "addressesGoal": [
        "tea:goal/transparency",
        "tea:goal/reliability",
        "tea:goal/safety"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/assurance-goal-category/transparency",
        "tea:tag/assurance-goal-category/reliability",
        "tea:tag/assurance-goal-category/safety",
        "tea:tag/data-type/any",
        "tea:tag/lifecycle-stage/project-planning",
        "tea:tag/lifecycle-stage/data-collection",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/lifecycle-stage/model-evaluation",
        "tea:tag/lifecycle-stage/deployment",
        "tea:tag/lifecycle-stage/post-deployment",
        "tea:tag/technique-type/procedural",
        "tea:tag/evidence-type/governance-framework",
        "tea:tag/evidence-type/documentation",
        "tea:tag/expertise-needed/software-engineering",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/data-requirements/no-special-requirements"
      ],
      "relatedTo": [
        "tea:technique/api-usage-pattern-monitoring",
        "tea:technique/out-of-domain-detection",
        "tea:technique/preferential-sampling",
        "tea:technique/relabelling"
      ],
      "citesResource": [
        "tea:resource/mlflowMlflow2018",
        "tea:resource/iterativeDvc2017",
        "tea:resource/foalemLoggingRequirementContinuous2025"
      ],
      "exampleUseCases": [
        {
          "description": "Maintaining detailed audit trails for medical AI development enabling investigators to trace how training data, model architecture, and evaluation decisions led to specific diagnostic behaviors during regulatory review.",
          "goal": "Transparency"
        },
        {
          "description": "Recording all model updates and performance changes over time to support root cause analysis when deployed systems exhibit unexpected behavior or reliability degradation.",
          "goal": "Reliability"
        },
        {
          "description": "Documenting safety-critical decisions like dataset filtering, bias testing, and red teaming results to demonstrate due diligence in preventing harmful deployments.",
          "goal": "Safety"
        },
        {
          "description": "Documenting credit scoring model development for regulatory compliance, maintaining detailed records of data sources, feature engineering decisions, fairness testing, and validation results to demonstrate adherence to fair lending requirements during audits.",
          "goal": "Transparency"
        },
        {
          "description": "Creating comprehensive audit trails for criminal justice risk assessment tools to enable external review of training data selection, bias mitigation techniques, and validation methodologies when legal challenges question algorithmic fairness.",
          "goal": "Fairness"
        },
        {
          "description": "Maintaining development logs for autonomous vehicle perception systems to support accident investigations, enabling forensic analysis of which model version was deployed, what training data informed its behavior, and what testing validated its safety.",
          "goal": "Safety"
        }
      ],
      "limitations": [
        {
          "description": "Comprehensive logging generates large volumes of data requiring significant storage infrastructure and data management."
        },
        {
          "description": "Audit trails may contain sensitive information about proprietary techniques, requiring careful access control and redaction procedures."
        },
        {
          "description": "Creating meaningful audit trails requires discipline and tooling integration that may slow development velocity."
        },
        {
          "description": "Retrospective analysis of audit trails can be time-consuming and requires expertise to extract actionable insights from complex logs."
        },
        {
          "description": "Implementing comprehensive audit trail systems requires integrating with diverse development tools (version control, experiment tracking, data pipelines), which can be complex and may require custom development for organisation-specific workflows."
        },
        {
          "description": "Storage costs can be substantial, with comprehensive model development projects generating terabytes of logs, experimental artifacts, and dataset versions requiring long-term retention for compliance purposes."
        }
      ],
      "sampleClaims": [
        {
          "text": "All model development decisions are traceable to documented rationale and identified decision-makers",
          "domain": "general",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The diagnostic system's training data lineage, architecture changes, and validation results are preserved in tamper-evident logs enabling regulatory review",
          "domain": "healthcare",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The model's unexpected behaviour can be investigated by tracing dataset versions, hyperparameter configurations, and evaluation metrics back to specific development phases",
          "domain": "finance",
          "assuranceGoal": "reliability"
        },
        {
          "text": "All safety-critical decisions during autonomous system development are recorded with timestamps, responsible parties, and justifications",
          "domain": "autonomous systems",
          "assuranceGoal": "safety"
        },
        {
          "text": "The environmental forecasting model's experimental results and deployment decisions are reproducible from archived configurations and versioned datasets",
          "domain": "environmental",
          "assuranceGoal": "reliability"
        }
      ]
    },
    {
      "@id": "tea:technique/adversarial-robustness-testing",
      "@type": "Technique",
      "name": "Adversarial Robustness Testing",
      "slug": "adversarial-robustness-testing",
      "description": "Adversarial robustness testing evaluates model resilience against intentionally crafted inputs designed to cause misclassification or malfunction. This technique generates adversarial examples through methods like FGSM, PGD, Carlini & Wagner (C&W) attacks, and AutoAttack to measure model vulnerability. Testing assesses both white-box scenarios (where attackers have full model access) and black-box scenarios (where attackers only observe inputs and outputs), measuring metrics like robust accuracy, attack success rates, and perturbation budgets required for successful attacks.",
      "addressesGoal": [
        "tea:goal/security",
        "tea:goal/reliability",
        "tea:goal/safety"
      ],
      "hasTag": [
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/architecture/neural-networks",
        "tea:tag/applicable-models/requirements/black-box",
        "tea:tag/applicable-models/requirements/white-box",
        "tea:tag/assurance-goal-category/security",
        "tea:tag/assurance-goal-category/reliability",
        "tea:tag/assurance-goal-category/safety",
