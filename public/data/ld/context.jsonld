{
  "@context": {
    "@version": 1.1,
    "tea": "https://alan-turing-institute.github.io/tea-techniques/ns/",
    "schema": "https://schema.org/",
    "skos": "http://www.w3.org/2004/02/skos/core#",

    "Technique": "tea:Technique",
    "AssuranceGoal": "tea:AssuranceGoal",
    "TagCategory": "tea:TagCategory",
    "Tag": "tea:Tag",
    "Resource": "tea:Resource",

    "name": "schema:name",
    "description": "schema:description",
    "slug": "tea:slug",
    "acronym": "tea:acronym",
    "url": "schema:url",

    "addressesGoal": {
      "@id": "tea:addressesGoal",
      "@type": "@id"
    },
    "hasTag": {
      "@id": "tea:hasTag",
      "@type": "@id"
    },
    "relatedTo": {
      "@id": "tea:relatedTo",
      "@type": "@id"
    },
    "citesResource": {
      "@id": "tea:citesResource",
      "@type": "@id"
    },

    "broader": {
      "@id": "skos:broader",
      "@type": "@id"
    },
    "narrower": {
      "@id": "skos:narrower",
      "@type": "@id"
    },
    "inScheme": {
      "@id": "skos:inScheme",
      "@type": "@id"
    },
    "prefLabel": "skos:prefLabel",

    "complexityRating": {
      "@id": "tea:complexityRating",
      "@type": "http://www.w3.org/2001/XMLSchema#integer"
    },
    "computationalCostRating": {
      "@id": "tea:computationalCostRating",
      "@type": "http://www.w3.org/2001/XMLSchema#integer"
    },
    "techniqueCount": {
      "@id": "tea:techniqueCount",
      "@type": "http://www.w3.org/2001/XMLSchema#integer"
    },

    "exampleUseCases": "tea:exampleUseCases",
    "limitations": "tea:limitations",
    "sampleClaims": "tea:sampleClaims",
    "goal": "tea:goal",

    "sourceType": "tea:sourceType",
    "authors": "schema:author",
    "publicationDate": "schema:datePublished",
    "abstract": "schema:abstract",
    "citationKey": "tea:citationKey",
    "category": "tea:category",
    "path": "tea:path",

    "hasTechnique": {
      "@id": "tea:hasTechnique",
      "@type": "@id"
    }
  }
}
