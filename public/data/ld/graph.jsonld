    {
      "@id": "tea:resource/aif360developersAif360algorithmspreprocessingDisparateImpactRemoverAif3602018",
      "@type": "Resource",
      "name": "aif360.algorithms.preprocessing.DisparateImpactRemover — aif360 ...",
      "citationKey": "aif360developersAif360algorithmspreprocessingDisparateImpactRemoverAif3602018",
