      "sourceType": "technical_paper",
      "authors": [
        "Faisal Kamiran",
        "Toon Calders"
      ],
      "publicationDate": "2012-06-01"
    },
    {
      "@id": "tea:resource/caldersClassifyingDiscriminating2010",
      "@type": "Resource",
      "name": "Classifying without discriminating",
      "citationKey": "caldersClassifyingDiscriminating2010",
      "url": "https://www.researchgate.net/publication/224440330_Classifying_without_discriminating",
      "sourceType": "technical_paper",
      "authors": [
