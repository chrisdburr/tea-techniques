        "tea:tag/technique-type/algorithmic",
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/requirements/black-box"
      ],
      "complexityRating": 4,
      "computationalCostRating": 5,
      "relatedTo": [
        "tea:technique/permutation-importance",
        "tea:technique/shapley-additive-explanations",
        "tea:technique/partial-dependence-plots",
        "tea:technique/local-interpretable-model-agnostic-explanations"
      ],
      "citesResource": [
        "tea:resource/ballester-ripollSobolTensorTrains2017",
        "tea:resource/uqpyprojectdevelopersSobolIndicesUQpy2017",
        "tea:resource/catherineSobolIndicesMeasure2022",
        "tea:resource/salibdevelopersBasicsSALibsDocumentation2025",
        "tea:resource/surgroupUQpy2017",
        "tea:resource/salibSALib2013"
      ],
      "exampleUseCases": [
        {
          "description": "Analysing a climate prediction model to determine which atmospheric parameters (temperature, humidity, pressure) contribute most to rainfall forecast uncertainty, helping meteorologists understand which measurements need the highest precision.",
          "goal": "Explainability"
        },
        {
          "description": "Evaluating a financial risk model to identify which economic indicators (interest rates, inflation, GDP growth) drive the most variability in portfolio value predictions, enabling better risk management strategies.",
          "goal": "Explainability"
        },
        {
          "description": "Analysing a credit scoring model to quantify how much prediction variance stems from zip code (a potential proxy for race), helping identify features that may cause disparate impact across demographic groups.",
          "goal": "Fairness"
        }
      ],
      "limitations": [
        {
          "description": "Computationally expensive, requiring thousands of model evaluations to achieve stable variance estimates, making it impractical for very slow models."
        },
        {
          "description": "Assumes input features are independently distributed, which can lead to misleading results when features are correlated in real data."
        },
        {
          "description": "Curse of dimensionality makes the technique increasingly difficult and expensive to apply as the number of input features grows beyond 10-20."
        },
        {
          "description": "Requires defining appropriate probability distributions for input features, which may not accurately reflect real-world feature distributions."
        }
      ],
      "sampleClaims": [
        {
          "text": "The flood prediction model's output uncertainty is quantifiably attributable to specific atmospheric measurements rather than distributed uniformly across all input features",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The financial risk model's variance decomposition reveals which economic indicators contribute most to prediction uncertainty through both direct effects and interactions with other variables",
          "domain": "finance",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The credit assessment system's sensitivity to zip code accounts for a quantifiable proportion of total prediction variance that can be compared against variance from financially relevant features",
          "domain": "finance",
          "assuranceGoal": "fairness"
        },
        {
          "text": "The autonomous navigation system's steering decisions have identifiable sources of variability traceable to specific sensor inputs and their interactions",
          "domain": "autonomous systems",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The clinical outcome predictor's total uncertainty can be decomposed into contributions from individual patient characteristics and their joint effects",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/local-interpretable-model-agnostic-explanations",
      "@type": "Technique",
      "name": "Local Interpretable Model-Agnostic Explanations",
      "slug": "local-interpretable-model-agnostic-explanations",
      "description": "LIME (Local Interpretable Model-agnostic Explanations) explains individual predictions by approximating the complex model's behaviour in a small neighbourhood around a specific instance. It works by creating perturbed versions of the input (e.g., removing words from text, changing pixel values in images, or varying feature values), obtaining the model's predictions for these variations, and training a simple interpretable model (typically linear regression) weighted by proximity to the original instance. The coefficients of this local surrogate model reveal which features most influenced the specific prediction.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/transparency"
      ],
      "hasTag": [
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/surrogate-models/local-surrogates",
        "tea:tag/assurance-goal-category/explainability/attribution-methods/perturbation-based",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/explains/decision-boundaries",
        "tea:tag/assurance-goal-category/explainability/property/fidelity",
        "tea:tag/assurance-goal-category/transparency",
        "tea:tag/data-requirements/no-special-requirements",
        "tea:tag/data-type/any",
        "tea:tag/evidence-type/qualitative-report",
        "tea:tag/evidence-type/quantitative-metric",
        "tea:tag/expertise-needed/ml-engineering",
        "tea:tag/explanatory-scope/local",
        "tea:tag/lifecycle-stage/model-development",
        "tea:tag/lifecycle-stage/system-deployment-and-use",
        "tea:tag/technique-type/algorithmic",
        "tea:tag/applicable-models/architecture/model-agnostic",
        "tea:tag/applicable-models/requirements/black-box"
      ],
      "acronym": "LIME",
      "complexityRating": 2,
      "computationalCostRating": 3,
      "relatedTo": [
        "tea:technique/shapley-additive-explanations",
        "tea:technique/anchor",
        "tea:technique/ridge-regression-surrogates",
        "tea:technique/partial-dependence-plots"
      ],
      "citesResource": [
        "tea:resource/marcotcrLime2016",
        "tea:resource/thomasp85Lime2017",
        "tea:resource/lime-mldevelopersLocalInterpretableModelAgnostic2016",
        "tea:resource/tulioribeiroWhyShouldTrust2016",
        "tea:resource/keretchashviliHowConvinceYour2022",
        "tea:resource/accelerated-data-sciencedevelopersEnhancedLIMEADS2021"
      ],
      "exampleUseCases": [
        {
          "description": "Explaining why a specific patient received a high-risk diagnosis by showing which symptoms (fever, blood pressure, age) contributed most to the prediction, helping doctors validate the AI's reasoning.",
          "goal": "Explainability"
        },
        {
          "description": "Debugging a text classifier's misclassification of a movie review by highlighting which words (e.g., sarcastic phrases) confused the model, enabling targeted model improvements.",
          "goal": "Explainability"
        },
        {
          "description": "Providing transparent explanations to customers about automated decisions in insurance claims, showing which claim features influenced approval or denial to meet regulatory requirements.",
          "goal": "Transparency"
        }
      ],
      "limitations": [
        {
          "description": "Explanations can be unstable due to random sampling, producing different results across multiple runs."
        },
        {
          "description": "The linear surrogate may poorly approximate highly non-linear model behaviour in the local region."
        },
        {
          "description": "Defining the neighbourhood size and perturbation strategy requires careful tuning for each data type."
        },
        {
          "description": "Can be computationally expensive for explaining many instances due to repeated model queries."
        }
      ],
      "sampleClaims": [
        {
          "text": "The fraud detection system's flagging of individual transactions is attributable to specific transaction features in the local decision context",
          "domain": "finance",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The medical diagnosis model's predictions for individual patients are interpretable through locally approximated feature contributions",
          "domain": "healthcare",
          "assuranceGoal": "explainability"
        },
        {
          "text": "The autonomous vehicle's object classification decisions are explainable to operators through feature-level analysis of specific detection instances",
          "domain": "autonomous systems",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The content moderation system provides interpretable explanations for individual moderation decisions without requiring access to model internals",
          "domain": "general",
          "assuranceGoal": "transparency"
        },
        {
          "text": "The environmental monitoring system's anomaly alerts are accompanied by explanations showing which sensor readings contributed to each specific detection",
          "domain": "environmental",
          "assuranceGoal": "explainability"
        }
      ]
    },
    {
      "@id": "tea:technique/ridge-regression-surrogates",
      "@type": "Technique",
      "name": "Ridge Regression Surrogates",
      "slug": "ridge-regression-surrogates",
      "description": "This technique approximates a complex model by training a ridge regression (a linear model with L2 regularisation) on the original model's predictions. The ridge regression serves as a global surrogate that balances fidelity and interpretability, capturing the main linear relationships that the complex model learned whilst ignoring noise due to regularisation. This approach is particularly useful when stakeholders need to understand the overall behaviour of a complex model through transparent linear coefficients.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/transparency"
      ],
      "hasTag": [
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/surrogate-models/global-surrogates",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/explains/decision-boundaries",
        "tea:tag/assurance-goal-category/explainability/property/fidelity",
        "tea:tag/assurance-goal-category/explainability/property/comprehensibility",
