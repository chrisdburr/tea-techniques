      ]
    },
    {
      "@id": "tea:resource/hallNONPARAMETRICKERNELREGRESSION2001",
      "@type": "Resource",
      "name": "NONPARAMETRIC KERNEL REGRESSION SUBJECT TO MONOTONICITY CONSTRAINTS",
      "citationKey": "hallNONPARAMETRICKERNELREGRESSION2001",
      "url": "https://www.semanticscholar.org/paper/28e2be532d66694d3fe3486671f5c0217f58892d",
      "sourceType": "technical_paper",
