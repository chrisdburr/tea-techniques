        "Databricks-sdk-py Developers"
      ],
      "publicationDate": "2023"
    },
    {
      "@id": "tea:resource/nvidia-nemoGuardrails2023",
      "@type": "Resource",
      "name": "Guardrails",
      "citationKey": "nvidia-nemoGuardrails2023",
      "url": "https://github.com/NVIDIA-NeMo/Guardrails",
