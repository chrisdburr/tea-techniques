      "@id": "tea:resource/hatanoPathSpecificCounterfactualFairness2025",
      "@type": "Resource",
      "name": "Path-Specific Counterfactual Fairness via Dividend Correction",
      "citationKey": "hatanoPathSpecificCounterfactualFairness2025",
