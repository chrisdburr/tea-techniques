    {
      "@id": "tea:technique/shapley-additive-explanations",
      "@type": "Technique",
      "name": "SHapley Additive exPlanations",
      "slug": "shapley-additive-explanations",
      "description": "SHAP explains model predictions by quantifying how much each input feature contributes to the outcome. It assigns an importance score to every feature, indicating whether it pushes the prediction towards or away from the average. The method systematically evaluates how predictions change as features are included or excluded, drawing on game theory concepts to ensure a fair distribution of contributions.",
      "addressesGoal": [
        "tea:goal/explainability",
        "tea:goal/fairness",
        "tea:goal/reliability"
      ],
      "hasTag": [
        "tea:tag/assurance-goal-category/explainability",
        "tea:tag/assurance-goal-category/explainability/attribution-methods/perturbation-based",
        "tea:tag/assurance-goal-category/explainability/explains/feature-importance",
        "tea:tag/assurance-goal-category/explainability/property/completeness",
        "tea:tag/assurance-goal-category/explainability/property/consistency",
        "tea:tag/assurance-goal-category/fairness",
        "tea:tag/assurance-goal-category/reliability",
