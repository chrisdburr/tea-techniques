        "tea:tag/assurance-goal-category/safety/risk-identification",
        "tea:tag/data-requirements/access-to-model-internals",
        "tea:tag/data-type/text",
        "tea:tag/evidence-type/causal-analysis",
        "tea:tag/evidence-type/documentation",
        "tea:tag/explanatory-scope/global",
        "tea:tag/explanatory-scope/local",
        "tea:tag/expertise-needed/causal-inference",
