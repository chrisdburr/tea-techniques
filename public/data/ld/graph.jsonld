    {
      "@id": "tea:resource/scikit-learndevelopersCrossvalidationEvaluatingEstimator2007",
      "@type": "Resource",
      "name": "Cross-validation: evaluating estimator performance",
      "citationKey": "scikit-learndevelopersCrossvalidationEvaluatingEstimator2007",
      "url": "https://scikit-learn.org/stable/modules/cross_validation.html",
