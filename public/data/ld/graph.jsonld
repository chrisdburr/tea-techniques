    {
      "@id": "tea:resource/InterpretableMachineLearning2019b",
      "@type": "Resource",
      "name": "Interpretable Machine Learning - Anchors",
      "citationKey": "InterpretableMachineLearning2019b",
      "url": "https://christophm.github.io/interpretable-ml-book/anchors.html",
